/* REV203 — DROP HERO BOTTLE THEATRE MOTION START
   Purpose: one GSAP-owned animation for the Drop route hero bottle set imported from preview (13).html.
   Rules: no second router, no substitute renderer, no Layering/Shop/Home motion changes. */
(function(){
  'use strict';
  var prefersReduced = false;
  try{ prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches; }catch(e){}

  function qsa(sel, root){ return Array.prototype.slice.call((root || document).querySelectorAll(sel)); }
  function activePage(){ return (document.body && document.body.dataset && document.body.dataset.page) || (location.hash || '#home').replace('#','') || 'home'; }

  function killHero(root){
    if(!window.gsap || !root) return;
    var items = qsa('.rev203-drop-bottle', root).concat(qsa('.rev203-bottle-scene,.rev203-drop-glow,.rev203-drop-caption,.rev203-drop-status-card', root));
    try{ gsap.killTweensOf(items); }catch(e){}
  }

  function playDropHero(force){
    var root = document.querySelector('[data-rev203-drop-hero="bottle-theatre"]');
    if(!root || activePage() !== 'drop') return;
    var scene = root.querySelector('.rev203-bottle-scene');
    var glow = root.querySelector('.rev203-drop-glow');
    var caption = root.querySelector('.rev203-drop-caption');
    var status = root.querySelector('.rev203-drop-status-card');
    var bottles = qsa('.rev203-drop-bottle', root);
    if(!scene || bottles.length < 4) return;

    if(prefersReduced || !window.gsap){
      root.dataset.rev203Motion = 'static-fallback';
      bottles.forEach(function(b){ b.style.opacity = '1'; });
      return;
    }

    if(root.dataset.rev203Played === 'true' && !force){ return; }
    root.dataset.rev203Played = 'true';
    root.dataset.rev203Motion = 'gsap-active';
    killHero(root);
    gsap.set(root, {opacity:1, y:0, clearProps:'transform'});

    gsap.set(scene, {opacity:1, rotateX:0, rotateY:0, transformOrigin:'50% 50%'});
    gsap.set(glow, {opacity:0, scale:.86, rotate:-18, transformOrigin:'50% 50%'});
    gsap.set(caption, {opacity:0, y:12});
    gsap.set(status, {opacity:0, y:24, scale:.965});
    gsap.set(bottles, {
      opacity:0,
      y:function(i){ return [78,102,92,108][i] || 88; },
      x:function(i){ return [-24,0,22,38][i] || 0; },
      scale:function(i){ return [.91,.88,.92,.92][i] || .9; },
      rotate:function(i){ return [-9,8,-6,7][i] || 0; },
      filter:'blur(8px) saturate(.9) drop-shadow(8px 22px 24px rgba(64,38,27,.12))',
      transformOrigin:'50% 92%'
    });

    var tl = gsap.timeline({defaults:{ease:'power3.out'}});
    tl.to(glow, {opacity:.86, scale:1.04, rotate:0, duration:.78, ease:'power2.out'}, 0)
      .to(scene, {rotateX:0, rotateY:0, duration:.8}, 0)
      .to(bottles, {
        opacity:1,
        y:0,
        x:0,
        scale:1,
        rotate:0,
        filter:'blur(0px) saturate(1.02) drop-shadow(18px 34px 34px rgba(64,38,27,.18)) drop-shadow(3px 8px 9px rgba(64,38,27,.12))',
        duration:.92,
        stagger:{each:.11, from:'start'},
        ease:'back.out(1.16)'
      }, .12)
      .to(caption, {opacity:1, y:0, duration:.42, ease:'power2.out'}, .72)
      .to(status, {opacity:1, y:0, scale:1, duration:.48, ease:'power2.out'}, .86);

    tl.add(function(){
      bottles.forEach(function(bottle, i){
        gsap.to(bottle, {
          y:i % 2 === 0 ? -7 : -4,
          rotate:[-1.2, .9, -.65, .7][i] || 0,
          duration:2.7 + i * .28,
          ease:'sine.inOut',
          yoyo:true,
          repeat:-1,
          overwrite:false
        });
      });
      gsap.to(glow, {scale:1.085, rotate:4, opacity:.96, duration:3.8, ease:'sine.inOut', yoyo:true, repeat:-1});
    });
  }

  function wireHover(){
    if(wireHover.done) return;
    wireHover.done = true;
    document.addEventListener('pointerenter', function(event){
      var bottle = event.target && event.target.closest && event.target.closest('.rev203-drop-bottle');
      if(!bottle || !window.gsap || prefersReduced) return;
      var bottles = qsa('.rev203-drop-bottle', bottle.closest('[data-rev203-drop-hero="bottle-theatre"]'));
      var index = bottles.indexOf(bottle);
      gsap.to(bottle, {y:-22, scale:1.045, rotate:[-2.2,1.6,-1.4,1.4][index] || 0, duration:.32, ease:'power2.out', overwrite:'auto'});
    }, true);
    document.addEventListener('pointerleave', function(event){
      var bottle = event.target && event.target.closest && event.target.closest('.rev203-drop-bottle');
      if(!bottle || !window.gsap || prefersReduced) return;
      gsap.to(bottle, {y:0, scale:1, rotate:0, duration:.42, ease:'power2.out', overwrite:'auto'});
    }, true);
  }

  function refresh(){
    wireHover();
    window.setTimeout(function(){ playDropHero(true); }, 80);
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', refresh, {once:true});
  }else{
    refresh();
  }
  window.addEventListener('tabaq:page-change', function(event){
    if(event && event.detail && event.detail.page === 'drop') refresh();
  });
  window.addEventListener('hashchange', function(){ if(activePage() === 'drop') refresh(); });
})();
/* REV203 — DROP HERO BOTTLE THEATRE MOTION END */


/* ======================================================================
   REV204 — SHOP KIT HOVER REVEAL MOTION
   Scope: Shop/Kits page only. Adds tactile opening behavior and GSAP
   entrance/float to the uploaded kit hover object. No router/cart/renderer
   changes; no changes to Rev203 Drop theatre or Layering route.
   ====================================================================== */
(function rev204ShopKitHoverReveal(){
  function isReducedMotion(){
    return !!(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches);
  }
  function isShopActive(){
    var page = document.querySelector('[data-page="shop"]');
    return !!page && page.classList.contains('is-active');
  }
  function initReveal(){
    var section = document.querySelector('.rev204-kit-reveal');
    var kit = section && section.querySelector('.rev204-kit');
    if(!section || !kit || kit.dataset.rev204Ready === '1') return;
    kit.dataset.rev204Ready = '1';

    kit.addEventListener('click', function(){
      kit.classList.toggle('is-open');
    });
    kit.addEventListener('keydown', function(event){
      if(event.key === 'Enter' || event.key === ' '){
        event.preventDefault();
        kit.classList.toggle('is-open');
      }
      if(event.key === 'Escape'){
        kit.classList.remove('is-open');
      }
    });

    var cta = section.querySelector('.rev204-kit-reveal__cta');
    if(cta){
      cta.addEventListener('click', function(event){
        var target = document.querySelector('#shopKitCollection');
        if(target){
          event.preventDefault();
          target.scrollIntoView({ behavior: isReducedMotion() ? 'auto' : 'smooth', block: 'start' });
        }
      });
    }

    if(!window.gsap || isReducedMotion()) return;
    var lid = kit.querySelector('.rev204-kit__lid');
    var tray = kit.querySelector('.rev204-kit__tray');
    var copy = section.querySelector('.rev204-kit-reveal__copy');
    var facts = section.querySelectorAll('.rev204-kit-reveal__facts span');
    var hint = section.querySelector('.rev204-kit-reveal__hint');

    window.gsap.set(section, { autoAlpha: 0, y: 38 });
    window.gsap.set([lid, tray], { transformOrigin: '50% 52%' });
    window.gsap.set(lid, { y: -18, rotate: -2.5, scale: 0.96, autoAlpha: 0 });
    window.gsap.set(tray, { y: 20, rotate: 2, scale: 0.96, autoAlpha: 0 });
    if(copy) window.gsap.set(copy, { y: 22, autoAlpha: 0 });
    if(facts.length) window.gsap.set(facts, { y: 12, autoAlpha: 0 });
    if(hint) window.gsap.set(hint, { y: 8, autoAlpha: 0 });

    function playIntro(){
      if(section.dataset.rev204Played === '1') return;
      if(!isShopActive() && location.hash && location.hash !== '#shop') return;
      section.dataset.rev204Played = '1';
      var tl = window.gsap.timeline({ defaults: { ease: 'power3.out' } });
      tl.to(section, { autoAlpha: 1, y: 0, duration: 0.56 })
        .to(copy, { autoAlpha: 1, y: 0, duration: 0.54 }, '-=0.34')
        .to(tray, { autoAlpha: 1, y: 0, rotate: -0.4, scale: 0.985, duration: 0.66 }, '-=0.34')
        .to(lid, { autoAlpha: 1, y: 0, rotate: 0, scale: 1, duration: 0.62 }, '-=0.50')
        .to(facts, { autoAlpha: 1, y: 0, duration: 0.36, stagger: 0.045 }, '-=0.36')
        .to(hint, { autoAlpha: 1, y: 0, duration: 0.32 }, '-=0.22');

      window.gsap.to(kit, {
        y: -7,
        rotate: 0.18,
        duration: 3.4,
        repeat: -1,
        yoyo: true,
        ease: 'sine.inOut',
        delay: 0.8
      });
    }

    if('IntersectionObserver' in window){
      var observer = new IntersectionObserver(function(entries){
        entries.forEach(function(entry){ if(entry.isIntersecting) playIntro(); });
      }, { threshold: 0.22 });
      observer.observe(section);
    } else {
      setTimeout(playIntro, 360);
    }
    window.addEventListener('hashchange', function(){ setTimeout(playIntro, 180); });
    document.addEventListener('click', function(){ setTimeout(playIntro, 220); }, true);
    window.addEventListener('load', function(){ setTimeout(playIntro, 280); });
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', initReveal);
  } else {
    initReveal();
  }
  window.addEventListener('load', initReveal);
  window.addEventListener('hashchange', function(){ setTimeout(initReveal, 120); });
})();
/* REV204 — SHOP KIT HOVER REVEAL MOTION END */


/* REV205 — COMING DROP KIT HOVER MOTION START
   Purpose: route-aware GSAP theatre for the uploaded clean-fit kit in the Drop page coming-drop section. */
(function(){
  'use strict';
  function qsa(sel, ctx){ return Array.prototype.slice.call((ctx || document).querySelectorAll(sel)); }
  function activePage(){ return (location.hash || '#home').replace('#','') || 'home'; }
  function isDropActive(){ return activePage() === 'drop'; }
  function reduced(){ return window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches; }
  function bindKit(kit){
    if(!kit || kit.dataset.rev205Bound === '1') return;
    kit.dataset.rev205Bound = '1';
    kit.setAttribute('aria-expanded', kit.classList.contains('is-open') ? 'true' : 'false');
    kit.addEventListener('keydown', function(event){
      if(event.key === 'Escape'){
        kit.classList.remove('is-open');
        kit.setAttribute('aria-expanded','false');
      }
    });
  }
  function syncAria(){
    qsa('[data-rev205-drop-kit-toggle]').forEach(function(kit){
      kit.setAttribute('aria-expanded', kit.classList.contains('is-open') ? 'true' : 'false');
    });
  }
  function init(){
    var stage = document.querySelector('[data-rev205-coming-drop-kit]');
    if(!stage) return;
    var kit = stage.querySelector('[data-rev205-drop-kit-toggle]');
    var tray = stage.querySelector('.rev205-drop-kit-hover__tray');
    var lid = stage.querySelector('.rev205-drop-kit-hover__lid');
    var chips = qsa('.rev205-coming-kit-signals span', stage);
    var caption = stage.querySelector('figcaption');
    bindKit(kit);
    if(stage.dataset.rev205ClickBound !== '1'){
      stage.dataset.rev205ClickBound = '1';
      document.addEventListener('click', function(event){
        if(event.target && event.target.closest && event.target.closest('[data-rev205-drop-kit-toggle]')){
          setTimeout(syncAria, 0);
        }
      }, true);
    }
    if(!window.gsap || reduced()) return;
    if(stage.dataset.rev205MotionBound === '1') return;
    stage.dataset.rev205MotionBound = '1';
    window.gsap.set([kit, tray, lid], { transformOrigin: '50% 50%' });
    window.gsap.set(kit, { autoAlpha: 0, y: 44, scale: 0.94, rotate: -1.6 });
    if(tray) window.gsap.set(tray, { y: 18, rotate: 1.2, filter: 'drop-shadow(0 12px 18px rgba(0,0,0,.10))' });
    if(lid) window.gsap.set(lid, { y: -14, rotate: -1.4 });
    if(chips.length) window.gsap.set(chips, { autoAlpha: 0, y: 12 });
    if(caption) window.gsap.set(caption, { autoAlpha: 0, y: 10 });
    function play(){
      if(stage.dataset.rev205Played === '1') return;
      if(!isDropActive()) return;
      stage.dataset.rev205Played = '1';
      var tl = window.gsap.timeline({ defaults: { ease: 'power3.out' } });
      tl.to(kit, { autoAlpha: 1, y: 0, scale: 1, rotate: 0, duration: 0.72 })
        .to(tray, { y: 0, rotate: 0, duration: 0.54 }, '-=0.42')
        .to(lid, { y: 0, rotate: 0, duration: 0.54 }, '-=0.50')
        .to(chips, { autoAlpha: 1, y: 0, duration: 0.34, stagger: 0.055 }, '-=0.22')
        .to(caption, { autoAlpha: 1, y: 0, duration: 0.30 }, '-=0.20');
      window.gsap.to(kit, {
        y: -8,
        rotate: 0.22,
        duration: 3.6,
        ease: 'sine.inOut',
        repeat: -1,
        yoyo: true,
        delay: 0.75
      });
    }
    if('IntersectionObserver' in window){
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(entry){ if(entry.isIntersecting) play(); });
      }, { threshold: 0.18 });
      io.observe(stage);
    } else {
      setTimeout(play, 300);
    }
    window.addEventListener('hashchange', function(){ setTimeout(play, 220); });
    window.addEventListener('load', function(){ setTimeout(play, 360); });
    document.addEventListener('click', function(){ setTimeout(play, 260); }, true);
  }
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
  window.addEventListener('load', init);
  window.addEventListener('hashchange', function(){ setTimeout(init, 120); });
})();
/* REV205 — COMING DROP KIT HOVER MOTION END */


/* REV206 — DROP KIT HOVER RUNTIME FIX START
   Purpose: repair the Rev205 coming-drop kit hover after GSAP intro transforms overrode the CSS hover state.
   Method: bind the kit directly, animate tray/lid on pointer/focus/tap, and watch the is-open class used by the existing Rev148 toggle system. */
(function rev206DropKitHoverRuntimeFix(){
  'use strict';
  function qs(sel, ctx){ return (ctx || document).querySelector(sel); }
  function qsa(sel, ctx){ return Array.prototype.slice.call((ctx || document).querySelectorAll(sel)); }
  function reduce(){ return !!(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches); }
  function animateKit(kit, open){
    if(!kit) return;
    var tray = qs('.rev205-drop-kit-hover__tray', kit);
    var lid = qs('.rev205-drop-kit-hover__lid', kit);
    kit.dataset.rev206HoverState = open ? 'open' : 'closed';
    kit.setAttribute('aria-expanded', open ? 'true' : 'false');
    if(!window.gsap || reduce()) return;
    var duration = open ? 0.72 : 0.56;
    var ease = open ? 'power3.out' : 'power2.out';
    if(tray){
      window.gsap.to(tray, {
        yPercent: open ? 100 : 0,
        y: 0,
        rotation: 0,
        duration: duration,
        ease: ease,
        overwrite: 'auto'
      });
    }
    if(lid){
      window.gsap.to(lid, {
        yPercent: open ? -3 : 0,
        y: 0,
        rotation: open ? -0.35 : 0,
        duration: duration,
        ease: ease,
        overwrite: 'auto'
      });
    }
  }
  function bind(){
    qsa('[data-rev205-drop-kit-toggle]').forEach(function(kit){
      if(kit.dataset.rev206Bound === '1') return;
      kit.dataset.rev206Bound = '1';
      kit.dataset.rev206HoverState = kit.classList.contains('is-open') ? 'open' : 'closed';

      kit.addEventListener('pointerenter', function(){ animateKit(kit, true); });
      kit.addEventListener('pointerleave', function(){ animateKit(kit, kit.classList.contains('is-open')); });
      kit.addEventListener('focus', function(){ animateKit(kit, true); });
      kit.addEventListener('blur', function(){ animateKit(kit, kit.classList.contains('is-open')); });
      kit.addEventListener('keydown', function(event){
        if(event.key === 'Enter' || event.key === ' '){
          window.setTimeout(function(){ animateKit(kit, kit.classList.contains('is-open')); }, 0);
        }
        if(event.key === 'Escape'){
          kit.classList.remove('is-open');
          animateKit(kit, false);
        }
      });

      var observer = new MutationObserver(function(mutations){
        mutations.forEach(function(mutation){
          if(mutation.type === 'attributes' && mutation.attributeName === 'class'){
            animateKit(kit, kit.classList.contains('is-open') || kit.matches(':hover'));
          }
        });
      });
      observer.observe(kit, { attributes: true, attributeFilter: ['class'] });
    });
  }
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bind, { once: true });
  else bind();
  window.addEventListener('load', bind);
  window.addEventListener('hashchange', function(){ window.setTimeout(bind, 120); });
  document.addEventListener('tabaq:page-change', function(){ window.setTimeout(bind, 80); });
})();
/* REV206 — DROP KIT HOVER RUNTIME FIX END */

/* REV207 — FULL COMMERCE FRONTEND + BACKEND HANDOFF START
   Purpose: final ecommerce polish and a real backend-aware checkout flow. It does not replace routing, renderer, hero, GSAP, or existing cart storage. */
(function(){
  'use strict';
  var root=document.documentElement;
  var body=document.body;
  var STORAGE_KEY='tabaq_rev138_cart';
  var PRODUCTS={
    'clean-skin':{id:'clean-skin',name:'Clean Skin',price:890,priceLabel:'R890',short:'Fresh daily kit',includes:['Mist','Eau de Parfum','Oil 01','Oil 02']},
    'soft-bloom':{id:'soft-bloom',name:'Soft Bloom',price:890,priceLabel:'R890',short:'Soft floral kit',includes:['Mist','Eau de Parfum','Oil 01','Oil 02']},
    'amber-haze':{id:'amber-haze',name:'Amber Haze',price:950,priceLabel:'R950',short:'Warm evening kit',includes:['Mist','Eau de Parfum','Oil 01','Oil 02']},
    'juice-drift':{id:'juice-drift',name:'Juice Drift',price:890,priceLabel:'R890',short:'Bright social kit',includes:['Mist','Eau de Parfum','Oil 01','Oil 02']}
  };
  function qs(s,c){return (c||document).querySelector(s);}
  function qsa(s,c){return Array.prototype.slice.call((c||document).querySelectorAll(s));}
  function readCart(){try{return JSON.parse(localStorage.getItem(STORAGE_KEY)||'{}')||{};}catch(e){return {};}}
  function itemCount(cart){return Object.keys(cart).reduce(function(sum,id){return sum+(Number(cart[id])||0);},0);}
  function cartLines(){
    var cart=readCart();
    return Object.keys(cart).filter(function(id){return PRODUCTS[id] && Number(cart[id])>0;}).map(function(id){return {id:id,quantity:Number(cart[id])||1};});
  }
  function setStatus(msg,isError){
    var note=qs('[data-rev207-checkout-status]') || qs('[data-rev138-checkout-note]');
    if(note){note.textContent=msg; note.dataset.rev207State=isError?'error':'ready';}
  }
  function polishButtons(){
    qsa('[data-rev138-add-cart]').forEach(function(btn){
      var id=btn.getAttribute('data-rev138-add-cart');
      var p=PRODUCTS[id];
      if(!p) return;
      if(/Add to cart/i.test(btn.textContent) || /Add complete kit/i.test(btn.textContent)){
        btn.textContent='Add complete kit — '+p.priceLabel;
      }
      btn.setAttribute('aria-label','Add '+p.name+' complete four-layer kit to cart');
    });
  }
  function polishCartLines(){
    qsa('[data-rev138-cart-line]').forEach(function(line){
      if(qs('.rev207-cart-line-proof',line)) return;
      var id=line.getAttribute('data-rev138-cart-line');
      var p=PRODUCTS[id];
      if(!p) return;
      var mount=line.querySelector('div');
      if(!mount) return;
      var proof=document.createElement('div');
      proof.className='rev207-cart-line-proof';
      proof.setAttribute('aria-label','Kit contents and readiness');
      proof.innerHTML='<span>Complete 4-layer kit</span><span>Wear in order</span><span>Ready now</span>';
      mount.appendChild(proof);
    });
  }
  function syncCommerceUI(){
    polishButtons();
    polishCartLines();
    var lines=cartLines();
    if(lines.length){
      setStatus('Ready for secure checkout. The backend creates the payment session and order record.',false);
    }
  }
  function isLocalFile(){return window.location.protocol==='file:';}
  function backendBase(){return isLocalFile()?'':window.location.origin;}
  async function startCheckout(){
    var lines=cartLines();
    if(!lines.length){
      setStatus('Add a kit first. Checkout only starts once a complete kit is in the cart.',true);
      return;
    }
    if(isLocalFile()){
      setStatus('Backend required for payments: run “npm start” in this folder, then open http://localhost:8787 and checkout again.',true);
      return;
    }
    body.classList.add('rev207-checkout-loading');
    setStatus('Creating secure checkout session…',false);
    try{
      var res=await fetch(backendBase()+'/api/checkout/session',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({items:lines,source:'tabaq-rev207-front-end'})
      });
      var data=await res.json().catch(function(){return {};});
      if(!res.ok){
        throw new Error(data.message || data.error || 'Checkout session could not be created.');
      }
      if(data.url){
        setStatus('Redirecting to secure checkout…',false);
        window.location.href=data.url;
        return;
      }
      throw new Error('Checkout response did not include a payment URL.');
    }catch(err){
      setStatus((err&&err.message?err.message:'Checkout is not available yet.')+' Cart is still saved.',true);
      root.dataset.rev207CheckoutState='checkout-error';
    }finally{
      body.classList.remove('rev207-checkout-loading');
    }
  }
  function bind(){
    root.classList.add('rev207-full-commerce-backend');
    syncCommerceUI();
    document.addEventListener('click',function(event){
      if(event.target.closest && event.target.closest('[data-rev138-checkout]')){
        event.preventDefault();
        window.setTimeout(startCheckout,20);
      }
      if(event.target.closest && (event.target.closest('[data-rev138-add-cart]') || event.target.closest('[data-rev138-qty]') || event.target.closest('[data-rev138-open-cart]'))){
        window.setTimeout(syncCommerceUI,80);
        window.setTimeout(syncCommerceUI,260);
      }
    },false);
    window.addEventListener('storage',syncCommerceUI);
    window.addEventListener('hashchange',function(){window.setTimeout(syncCommerceUI,90);});
    window.addEventListener('tabaq:page-change',function(){window.setTimeout(syncCommerceUI,120);});
    root.dataset.rev207Commerce='frontend-backend-handoff-ready';
    window.TABAQ_REV207_CHECKOUT={cartLines:cartLines,startCheckout:startCheckout,sync:syncCommerceUI};
  }
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',bind,{once:true});else bind();
})();
/* REV207 — FULL COMMERCE FRONTEND + BACKEND HANDOFF END */
