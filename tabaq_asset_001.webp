/* REV84 — GSAP COMMERCE MOTION WITHOUT DESIGN DRIFT START
   Purpose: make restored Rev71 commerce surfaces feel spatial and premium. Hero selectors are intentionally excluded. */
(function(){
  var CARD_SELECTOR = '.tabaq-page[data-page="shop"] .rev84-motion-card, .tabaq-page[data-page^="product-"] .rev84-motion-card';
  var ZONE_SELECTOR = '.tabaq-page[data-page="shop"] .rev84-motion-zone, .tabaq-page[data-page^="product-"] .rev84-motion-zone';
  var profiles = [
    {x:-22,y:48,z:-80,rx:7,ry:-8,rz:-1.2,d:.78,e:'power3.out'},
    {x:18,y:58,z:-120,rx:-5,ry:10,rz:1,d:.86,e:'expo.out'},
    {x:-8,y:66,z:-150,rx:9,ry:5,rz:-.7,d:.92,e:'power4.out'},
    {x:24,y:40,z:-70,rx:-7,ry:-6,rz:1.2,d:.74,e:'back.out(1.25)'}
  ];
  function ready(fn){ if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', fn, {once:true}); else fn(); }
  function reduced(){ return window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches; }
  function init(){
    var cards = Array.prototype.slice.call(document.querySelectorAll(CARD_SELECTOR));
    if(!cards.length) return;
    if(reduced() || !window.gsap){
      cards.forEach(function(card){ card.style.opacity = '1'; card.style.transform = 'none'; });
      return;
    }
    if(window.ScrollTrigger && gsap.registerPlugin){ try{ gsap.registerPlugin(ScrollTrigger); }catch(e){} }
    cards.forEach(function(card, index){
      if(card.dataset.rev84MotionReady === 'true') return;
      card.dataset.rev84MotionReady = 'true';
      var p = profiles[index % profiles.length];
      gsap.fromTo(card,
        {autoAlpha:0,x:p.x,y:p.y,z:p.z,rotateX:p.rx,rotateY:p.ry,rotateZ:p.rz,transformPerspective:1100,transformOrigin:'50% 76%',force3D:true},
        {autoAlpha:1,x:0,y:0,z:0,rotateX:0,rotateY:0,rotateZ:0,duration:p.d,ease:p.e,delay:(index%4)*.025,overwrite:true,force3D:true,
          scrollTrigger: window.ScrollTrigger ? {trigger:card,start:'top 88%',once:true} : null}
      );
    });
    Array.prototype.slice.call(document.querySelectorAll(ZONE_SELECTOR)).forEach(function(zone){
      if(zone.dataset.rev84PointerReady === 'true') return;
      zone.dataset.rev84PointerReady = 'true';
      var zoneCards = Array.prototype.slice.call(zone.querySelectorAll('.rev84-motion-card'));
      if(!zoneCards.length) return;
      zone.addEventListener('pointermove', function(event){
        var rect = zone.getBoundingClientRect();
        var x = (event.clientX - rect.left) / Math.max(rect.width,1) - .5;
        var y = (event.clientY - rect.top) / Math.max(rect.height,1) - .5;
        zoneCards.forEach(function(card, i){
          var depth = (i % 4) + 1;
          gsap.to(card,{x:x*(4+depth*2),y:y*(-3-depth),z:Math.abs(x-y)*(10+depth*5),rotateY:x*(3+depth*1.4),rotateX:y*(-2.6-depth),duration:.42+(i%3)*.035,ease:'power3.out',overwrite:true,force3D:true});
          var image = card.querySelector('img');
          if(image) gsap.to(image,{x:x*(6+depth),y:y*(-5-depth),scale:1.01,duration:.5,ease:'power3.out',overwrite:true});
        });
      }, {passive:true});
      zone.addEventListener('pointerleave', function(){
        zoneCards.forEach(function(card){
          gsap.to(card,{x:0,y:0,z:0,rotateX:0,rotateY:0,duration:.72,ease:'elastic.out(1,.72)',overwrite:true,force3D:true});
          var image = card.querySelector('img');
          if(image) gsap.to(image,{x:0,y:0,scale:1,duration:.7,ease:'power3.out',overwrite:true});
        });
      }, {passive:true});
    });
    if(window.ScrollTrigger) { try{ window.ScrollTrigger.refresh(); }catch(e){} }
  }
  ready(init);
  window.addEventListener('tabaq:page-change', function(){ window.setTimeout(init, 90); });
})();
