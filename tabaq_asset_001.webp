/* REV85 — GSAP EDITORIAL KIT SYSTEM START
   Purpose: make the product proof section explain the four-step kit through spatial motion.
   Guard: no hero selectors, no global scroll hijack, reduced-motion fallback included. */
(function(){
  var ROOT = '.rev85-editorial-kit-system';
  function ready(fn){ if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', fn, {once:true}); else fn(); }
  function reduced(){ return window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches; }
  function init(){
    var sections = Array.prototype.slice.call(document.querySelectorAll(ROOT));
    if(!sections.length) return;
    if(!window.gsap || reduced()){
      sections.forEach(function(sec){ sec.querySelectorAll('.rev85-stack-item,.rev85-keyword-rail b,.rev85-flow-bar i').forEach(function(el){ el.style.opacity='1'; el.style.transform='none'; }); });
      return;
    }
    if(window.ScrollTrigger && gsap.registerPlugin){ try{ gsap.registerPlugin(ScrollTrigger); }catch(e){} }
    sections.forEach(function(sec){
      if(sec.dataset.rev85Ready === 'true') return;
      sec.dataset.rev85Ready = 'true';
      var words = Array.prototype.slice.call(sec.querySelectorAll('.rev85-system-copy h2 em'));
      var keys = Array.prototype.slice.call(sec.querySelectorAll('.rev85-keyword-rail b'));
      var board = sec.querySelector('.rev85-kit-board');
      var items = Array.prototype.slice.call(sec.querySelectorAll('.rev85-stack-item'));
      var flow = Array.prototype.slice.call(sec.querySelectorAll('.rev85-flow-bar i'));
      var trigger = window.ScrollTrigger ? {trigger:sec,start:'top 74%',once:true} : null;
      var tl = gsap.timeline({defaults:{overwrite:true}, scrollTrigger:trigger});
      tl.fromTo(words,{autoAlpha:0,y:34,rotateX:-14,transformPerspective:900},{autoAlpha:1,y:0,rotateX:0,duration:.78,stagger:.055,ease:'expo.out',force3D:true},0);
      tl.fromTo(board,{autoAlpha:0,y:42,z:-160,rotateX:7,rotateY:-5,transformPerspective:1200},{autoAlpha:1,y:0,z:0,rotateX:0,rotateY:0,duration:1.05,ease:'power4.out',force3D:true},.08);
      tl.fromTo(keys,{autoAlpha:0,x:-18,y:20,z:-70,rotateY:-12,transformPerspective:900},{autoAlpha:1,x:0,y:0,z:0,rotateY:0,duration:.72,stagger:.055,ease:'power3.out',force3D:true},.22);
      tl.fromTo(flow,{scaleX:0,transformOrigin:'0% 50%'},{scaleX:1,duration:.72,stagger:.045,ease:'power2.out'},.36);
      items.forEach(function(item, i){
        var profile = [
          {x:-54,y:54,z:-210,rx:9,ry:-16,rz:-7,d:1.02,e:'expo.out'},
          {x:16,y:42,z:-150,rx:-6,ry:12,rz:4,d:.96,e:'power4.out'},
          {x:-10,y:48,z:-120,rx:8,ry:-7,rz:-4,d:.88,e:'back.out(1.18)'},
          {x:48,y:38,z:-180,rx:-9,ry:14,rz:7,d:1.04,e:'expo.out'}
        ][i%4];
        tl.fromTo(item,{autoAlpha:0,x:profile.x,y:profile.y,z:profile.z,rotateX:profile.rx,rotateY:profile.ry,rotateZ:profile.rz,scale:.94,transformPerspective:1200,transformOrigin:'50% 86%'},{autoAlpha:1,x:0,y:0,z:0,rotateX:0,rotateY:0,rotateZ:0,scale:1,duration:profile.d,ease:profile.e,force3D:true},.46+i*.085);
      });
      if(board){
        board.addEventListener('pointermove', function(event){
          var rect = board.getBoundingClientRect();
          var x = (event.clientX - rect.left) / Math.max(rect.width,1) - .5;
          var y = (event.clientY - rect.top) / Math.max(rect.height,1) - .5;
          gsap.to(board,{rotateY:x*3.2,rotateX:y*-2.4,duration:.55,ease:'power3.out',overwrite:true,force3D:true});
          items.forEach(function(item, i){
            var depth = i+1;
            gsap.to(item,{x:x*(5+depth*3),y:y*(-4-depth*2),z:Math.abs(x-y)*(18+depth*8),rotateY:x*(2.5+depth),rotateX:y*(-2-depth*.7),duration:.5+i*.025,ease:'power3.out',overwrite:true,force3D:true});
            var img = item.querySelector('img');
            if(img) gsap.to(img,{x:x*(8+depth*2),y:y*(-6-depth),scale:1.012,duration:.55,ease:'power3.out',overwrite:true,force3D:true});
          });
        }, {passive:true});
        board.addEventListener('pointerleave', function(){
          gsap.to(board,{rotateX:0,rotateY:0,duration:.9,ease:'elastic.out(1,.75)',overwrite:true,force3D:true});
          items.forEach(function(item){
            gsap.to(item,{x:0,y:0,z:0,rotateX:0,rotateY:0,duration:.82,ease:'elastic.out(1,.78)',overwrite:true,force3D:true});
            var img = item.querySelector('img');
            if(img) gsap.to(img,{x:0,y:0,scale:1,duration:.7,ease:'power3.out',overwrite:true});
          });
        }, {passive:true});
      }
    });
    if(window.ScrollTrigger) { try{ window.ScrollTrigger.refresh(); }catch(e){} }
  }
  ready(init);
  window.addEventListener('tabaq:page-change', function(){ window.setTimeout(init, 80); });
})();
/* REV85 — GSAP EDITORIAL KIT SYSTEM END */


/* REV87 — SCROLL SURGICAL FIX START
   Purpose: restore native, easy scrolling and keep only safe GSAP depth on the Layering page.
   Guardrails: no wheel listener, no keydown hijack, no scroll blocking, no hero selectors. */
(function(){
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var ready = function(fn){ document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', fn, {once:true}) : fn(); };
  ready(function(){
    var gsap = window.gsap;
    if(!gsap || reduce) return;

    function initLayeringDepth(){
      var page = document.querySelector('.tabaq-page[data-page="layering"]');
      if(!page || page.dataset.rev87DepthReady === 'true') return;
      page.dataset.rev87DepthReady = 'true';
      var roles = Array.prototype.slice.call(page.querySelectorAll('.rev72-layer-role'));
      if(!roles.length) return;
      if(window.ScrollTrigger && gsap.registerPlugin){ try{ gsap.registerPlugin(ScrollTrigger); }catch(e){} }
      roles.forEach(function(card, index){
        var img = card.querySelector('img');
        gsap.set(card, {transformPerspective:1200, transformOrigin:'50% 70%'});
        gsap.fromTo(card,
          {autoAlpha:0, y:38, z:-58, rotateX:5, rotateY:index % 2 ? -3.5 : 3.5},
          {autoAlpha:1, y:0, z:0, rotateX:0, rotateY:0, duration:.86, ease:'power3.out', delay:index*.035,
            scrollTrigger: window.ScrollTrigger ? {trigger:card,start:'top 88%',once:true} : null}
        );
        if(img){
          gsap.to(img, {y:index % 2 ? -12 : 12, rotateZ:index % 2 ? -.8 : .8, ease:'none',
            scrollTrigger: window.ScrollTrigger ? {trigger:card,start:'top bottom',end:'bottom top',scrub:.45} : null});
        }
      });
      if(window.ScrollTrigger){ try{ window.ScrollTrigger.refresh(); }catch(e){} }
    }

    initLayeringDepth();
    window.addEventListener('tabaq:page-change', function(event){
      var page = event && event.detail && event.detail.page;
      if(page === 'layering') window.setTimeout(initLayeringDepth, 100);
    });
    window.addEventListener('hashchange', function(){
      if(String(location.hash).replace('#','') === 'layering') window.setTimeout(initLayeringDepth, 100);
    });
  });
})();
/* REV87 — SCROLL SURGICAL FIX END */


/* REV88 — EDITORIAL COMMERCE RHYTHM START
   Purpose: move the current design forward without changing direction.
   Motion rule: commerce elements should feel authored, varied, and light; no global scroll hijack. */
(function(){
  function ready(fn){
    if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', fn, {once:true});
    else fn();
  }
  ready(function(){
    if(!window.gsap) return;
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if(reduce) return;
    var targets = Array.prototype.slice.call(document.querySelectorAll('.rev84-kit-compare, .product-card.rev43-commerce-card, .rev43-detail-panel'));
    targets.forEach(function(el, index){
      if(el.dataset.rev88RhythmReady === 'true') return;
      el.dataset.rev88RhythmReady = 'true';
      var angle = index % 3 === 0 ? -3.5 : index % 3 === 1 ? 2.6 : -1.4;
      gsap.fromTo(el,
        {autoAlpha:.72, y:44, rotateX:angle, z:-48, transformPerspective:1200},
        {autoAlpha:1, y:0, rotateX:0, z:0, duration:1.05, ease:'power3.out',
          scrollTrigger: window.ScrollTrigger ? {trigger:el, start:'top 86%', once:true} : undefined}
      );
    });
  });
})();
/* REV88 — EDITORIAL COMMERCE RHYTHM END */

/* REV91 — HERO MOTION RESTORE + SAFE SHOP CLICK START
   Purpose: restore previous hero bottle flight motion by removing aggressive approach-state cleanup.
   Guard: no scroll hijack, no hero animation rewrite, no visual redesign. */
(function(){
  function qs(sel, root){ return (root || document).querySelector(sel); }
  function qsa(sel, root){ return Array.prototype.slice.call((root || document).querySelectorAll(sel)); }
  function isHomePage(){ return !document.body.dataset.page || document.body.dataset.page === 'home'; }

  function clearFlightOnlyAtSafeReset(){
    qsa('.layer-kit-flight-clone').forEach(function(node){
      if(window.gsap) window.gsap.killTweensOf(node);
      node.remove();
    });
    qsa('#layers .card__media img.is-layer-kit-flight-target').forEach(function(img){
      img.classList.remove('is-layer-kit-flight-target');
      img.style.opacity = '';
      img.style.visibility = '';
    });
    qsa('#layers .card.is-layer-kit-flight-destination').forEach(function(card){
      card.classList.remove('is-layer-kit-flight-destination');
    });
  }

  function restoreHeroOnlyWhenSafe(force){
    var hero = qs('.hero');
    var handoff = qs('.handoff');
    if(!hero || !handoff) return;
    var nearTop = window.scrollY < Math.max(48, window.innerHeight * .12);
    var awayFromHome = !isHomePage();
    if(!force && !nearTop && !awayFromHome) return;

    hero.classList.remove('is-handoff-active');
    hero.classList.remove('rev90-handoff-approach');
    handoff.classList.remove('is-product-following');
    clearFlightOnlyAtSafeReset();

    var stage = qs('.stage', hero);
    if(stage){
      stage.classList.remove('is-scroll-following');
      stage.style.opacity = '';
      stage.style.visibility = '';
      stage.style.transform = '';
    }
    qsa('.float-item', hero).forEach(function(item){
      item.style.opacity = '';
      item.style.visibility = '';
      item.style.transform = '';
    });
  }

  var raf = 0;
  function onScroll(){
    if(raf) return;
    raf = requestAnimationFrame(function(){
      raf = 0;
      if(window.scrollY < Math.max(48, window.innerHeight * .12)) restoreHeroOnlyWhenSafe(true);
    });
  }
  window.addEventListener('scroll', onScroll, {passive:true});
  window.addEventListener('pageshow', function(){ restoreHeroOnlyWhenSafe(true); }, {passive:true});
  window.addEventListener('hashchange', function(){ window.setTimeout(function(){ restoreHeroOnlyWhenSafe(true); }, 0); });
  window.addEventListener('tabaq:page-change', function(){ window.setTimeout(function(){ restoreHeroOnlyWhenSafe(true); }, 0); });

  function kitToPage(kitId){ return kitId ? 'product-' + kitId : ''; }
  function openKitPage(kitId){
    var page = kitToPage(kitId);
    if(!page) return;
    var link = document.querySelector('[data-page-link="' + page + '"]');
    if(link){ link.click(); return; }
    if(location.hash !== '#' + page){ location.hash = '#' + page; }
    else window.dispatchEvent(new HashChangeEvent('hashchange'));
  }

  document.addEventListener('click', function(event){
    var shopCard = event.target.closest && event.target.closest('.tabaq-page[data-page="shop"] .product-card[data-kit-id]');
    if(!shopCard) return;
    if(event.target.closest('.rev48-card-drop-cta,[data-rev43-add],.secondary,a,button')) return;
    event.preventDefault();
    event.stopPropagation();
    if(event.stopImmediatePropagation) event.stopImmediatePropagation();
    openKitPage(shopCard.dataset.kitId);
  }, true);
})();
/* REV91 — HERO MOTION RESTORE + SAFE SHOP CLICK END */



/* REV92 — FORWARD SHOP PACK CLICK-THROUGH START
   Purpose: build forward from Rev91. Hover still opens the kit box; click/keyboard on the box opens the kit detail page.
   Scope: Shop kit box buttons only. No hero, router, or product layout changes. */
(function(){
  function openKitPage(kitId){
    if(!kitId) return;
    var page = 'product-' + kitId;
    var link = document.querySelector('[data-page-link="' + page + '"]');
    if(link){
      link.click();
      return;
    }
    if(location.hash !== '#' + page){
      location.hash = '#' + page;
    }else{
      window.dispatchEvent(new HashChangeEvent('hashchange'));
    }
  }

  function targetShopPack(event){
    var target = event.target;
    if(!target || !target.closest) return null;
    return target.closest('.tabaq-page[data-page="shop"] .product-card[data-kit-id] .rev29-pack[data-kit-toggle]');
  }

  document.addEventListener('click', function(event){
    var pack = targetShopPack(event);
    if(!pack) return;
    var card = pack.closest('.product-card[data-kit-id]');
    if(!card) return;
    event.preventDefault();
    event.stopPropagation();
    if(event.stopImmediatePropagation) event.stopImmediatePropagation();
    openKitPage(card.dataset.kitId);
  }, true);

  document.addEventListener('keydown', function(event){
    if(event.key !== 'Enter' && event.key !== ' ') return;
    var pack = targetShopPack(event);
    if(!pack) return;
    var card = pack.closest('.product-card[data-kit-id]');
    if(!card) return;
    event.preventDefault();
    event.stopPropagation();
    if(event.stopImmediatePropagation) event.stopImmediatePropagation();
    openKitPage(card.dataset.kitId);
  }, true);
})();
/* REV92 — FORWARD SHOP PACK CLICK-THROUGH END */


/* REV93 — CURATED JOURNEY MOTION START
   Purpose: motion supports page clarity; no scroll hijack, no hero changes. */
(function(){
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  function qsa(sel, root){ return Array.prototype.slice.call((root || document).querySelectorAll(sel)); }
  function activePage(){ return document.querySelector('.tabaq-page.is-active'); }
  function runRev93(page){
    if(reduce || !window.gsap) return;
    var root = page || activePage();
    if(!root || !root.classList.contains('rev93-journey-page')) return;
    var cards = qsa('.rev93-motion-card', root);
    window.gsap.set(cards, {opacity:0.001, y:28, rotateX:-5, transformPerspective:900, transformOrigin:'50% 80%'});
    window.gsap.to(cards, {opacity:1, y:0, rotateX:0, duration:.82, stagger:.055, ease:'power3.out', overwrite:'auto'});
    qsa('.rev93-motion-stage', root).forEach(function(stage, sIndex){
      window.gsap.fromTo(stage, {opacity:.001, y:36, rotateY:sIndex % 2 ? -4 : 4, scale:.985, transformPerspective:1100}, {opacity:1, y:0, rotateY:0, scale:1, duration:1.04, ease:'power3.out', overwrite:'auto', delay:.08});
    });
  }
  function installParallax(){
    if(reduce || !window.gsap) return;
    qsa('.rev93-motion-stage').forEach(function(stage){
      if(stage.dataset.rev93Parallax) return;
      stage.dataset.rev93Parallax = 'ready';
      stage.addEventListener('pointermove', function(event){
        var r = stage.getBoundingClientRect();
        var x = ((event.clientX - r.left) / Math.max(r.width,1)) - .5;
        var y = ((event.clientY - r.top) / Math.max(r.height,1)) - .5;
        window.gsap.to(stage, {rotateY:x*5.5, rotateX:-y*4.5, duration:.55, ease:'power3.out', overwrite:'auto'});
        qsa('img,.rev93-mood-card,.rev93-access-step', stage).forEach(function(el, i){
          window.gsap.to(el, {x:x*(8+i*1.5), y:y*(7+i), duration:.62, ease:'power3.out', overwrite:'auto'});
        });
      }, {passive:true});
      stage.addEventListener('pointerleave', function(){
        window.gsap.to(stage, {rotateY:0, rotateX:0, duration:.7, ease:'power3.out', overwrite:'auto'});
        qsa('img,.rev93-mood-card,.rev93-access-step', stage).forEach(function(el){ window.gsap.to(el, {x:0, y:0, duration:.7, ease:'power3.out', overwrite:'auto'}); });
      }, {passive:true});
    });
  }
  function boot(){
    installParallax();
    window.setTimeout(function(){ runRev93(); }, 90);
  }
  window.addEventListener('tabaq:page-change', function(event){
    var name = event && event.detail && event.detail.page;
    var page = name ? document.querySelector('.tabaq-page[data-page="' + name + '"]') : activePage();
    window.setTimeout(function(){ runRev93(page); installParallax(); }, 80);
  });
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot, {once:true});
  else boot();
})();
/* REV93 — CURATED JOURNEY MOTION END */

/* REV94 — CURATED JOURNEY MOTION START
   Purpose: choreograph decisive journey pages without scroll hijack or hero changes. */
(function(){
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  function qsa(sel, root){ return Array.prototype.slice.call((root || document).querySelectorAll(sel)); }
  function activePage(){ return document.querySelector('.tabaq-page.is-active'); }
  function runRev94(page){
    if(reduce || !window.gsap) return;
    var root = page || activePage();
    if(!root || !root.classList.contains('rev94-journey-page')) return;
    var copy = qsa('.rev94-copy > *', root);
    var cards = qsa('.rev94-motion-card,.rev94-mood-tile,.rev94-drop-kit,.rev94-proof-strip article,.rev94-access-step', root);
    window.gsap.set(copy, {opacity:0.001, y:26, rotateX:-3, transformPerspective:900, transformOrigin:'50% 80%'});
    window.gsap.to(copy, {opacity:1, y:0, rotateX:0, duration:.82, stagger:.055, ease:'power3.out', overwrite:'auto'});
    window.gsap.set(cards, {opacity:0.001, y:34, rotateX:-5, rotateY:function(i){return i%2 ? -2.5 : 2.5;}, transformPerspective:1000, transformOrigin:'50% 70%'});
    window.gsap.to(cards, {opacity:1, y:0, rotateX:0, rotateY:0, duration:.92, stagger:.055, ease:'power3.out', overwrite:'auto', delay:.08});
    qsa('.rev94-motion-stage', root).forEach(function(stage, sIndex){
      window.gsap.fromTo(stage, {opacity:.001, y:42, rotateY:sIndex % 2 ? -4 : 4, scale:.985, transformPerspective:1200}, {opacity:1, y:0, rotateY:0, scale:1, duration:1.08, ease:'power3.out', overwrite:'auto', delay:.06});
    });
  }
  function installDepth(){
    if(reduce || !window.gsap) return;
    qsa('.rev94-motion-stage,.rev94-mood-tile,.rev94-drop-kit').forEach(function(stage){
      if(stage.dataset.rev94Depth) return;
      stage.dataset.rev94Depth = 'ready';
      stage.addEventListener('pointermove', function(event){
        var r = stage.getBoundingClientRect();
        var x = ((event.clientX - r.left) / Math.max(r.width,1)) - .5;
        var y = ((event.clientY - r.top) / Math.max(r.height,1)) - .5;
        window.gsap.to(stage, {rotateY:x*4.5, rotateX:-y*3.5, duration:.55, ease:'power3.out', overwrite:'auto'});
        qsa('img,.rev94-access-step,.rev94-step-stack', stage).forEach(function(el, i){
          window.gsap.to(el, {x:x*(8+i*2), y:y*(6+i*1.5), duration:.62, ease:'power3.out', overwrite:'auto'});
        });
      }, {passive:true});
      stage.addEventListener('pointerleave', function(){
        window.gsap.to(stage, {rotateY:0, rotateX:0, duration:.72, ease:'power3.out', overwrite:'auto'});
        qsa('img,.rev94-access-step,.rev94-step-stack', stage).forEach(function(el){
          window.gsap.to(el, {x:0, y:0, duration:.72, ease:'power3.out', overwrite:'auto'});
        });
      }, {passive:true});
    });
  }
  function boot(){ installDepth(); window.setTimeout(function(){ runRev94(); }, 120); }
  window.addEventListener('tabaq:page-change', function(event){
    var pageName = event && event.detail && event.detail.page;
    var page = pageName ? document.querySelector('.tabaq-page[data-page="' + pageName + '"]') : activePage();
    window.setTimeout(function(){ installDepth(); runRev94(page); }, 90);
  });
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot, {once:true});
  else boot();
})();
/* REV94 — CURATED JOURNEY MOTION END */

/* REV95 — PRODUCT-LED ORDER MOTION START
   Purpose: direct product order visual replaces abstract layer-map disc. No scroll hijack. */
(function(){
  var ready = function(fn){ document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', fn, {once:true}) : fn(); };
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  function init(){
    if(!window.gsap || reduce) return;
    if(window.ScrollTrigger && gsap.registerPlugin){ try{ gsap.registerPlugin(ScrollTrigger); }catch(e){} }
    document.querySelectorAll('.rev95-handoff-order').forEach(function(order){
      if(order.dataset.rev95Ready === 'true') return;
      order.dataset.rev95Ready = 'true';
      var chips = Array.prototype.slice.call(order.querySelectorAll('span'));
      gsap.fromTo(chips,
        {autoAlpha:0,y:28,z:-120,rotateX:-12,rotateY:8,transformPerspective:900},
        {autoAlpha:1,y:0,z:0,rotateX:0,rotateY:0,duration:.82,stagger:.055,ease:'power4.out',force3D:true,
          scrollTrigger: window.ScrollTrigger ? {trigger:order,start:'top 82%',once:true} : null}
      );
      order.addEventListener('pointermove', function(e){
        var r=order.getBoundingClientRect();
        var x=(e.clientX-r.left)/Math.max(r.width,1)-.5;
        var y=(e.clientY-r.top)/Math.max(r.height,1)-.5;
        chips.forEach(function(chip,i){
          gsap.to(chip,{x:x*(4+i*1.8),y:y*(-3-i),z:Math.abs(x-y)*(12+i*8),rotateY:x*(4+i),rotateX:y*(-3-i*.6),duration:.42+i*.025,ease:'power3.out',overwrite:true,force3D:true});
        });
      }, {passive:true});
      order.addEventListener('pointerleave', function(){
        chips.forEach(function(chip){ gsap.to(chip,{x:0,y:0,z:0,rotateX:0,rotateY:0,duration:.7,ease:'elastic.out(1,.75)',overwrite:true,force3D:true}); });
      }, {passive:true});
    });
    document.querySelectorAll('.rev95-order-board-figure').forEach(function(frame){
      if(frame.dataset.rev95Ready === 'true') return;
      frame.dataset.rev95Ready = 'true';
      var img = frame.querySelector('img');
      gsap.fromTo(frame,
        {autoAlpha:0,y:36,z:-120,rotateX:5,transformPerspective:1200},
        {autoAlpha:1,y:0,z:0,rotateX:0,duration:1.05,ease:'power4.out',force3D:true,
          scrollTrigger: window.ScrollTrigger ? {trigger:frame,start:'top 78%',once:true} : null}
      );
      frame.addEventListener('pointermove', function(e){
        var r=frame.getBoundingClientRect();
        var x=(e.clientX-r.left)/Math.max(r.width,1)-.5;
        var y=(e.clientY-r.top)/Math.max(r.height,1)-.5;
        gsap.to(frame,{rotateY:x*2.8,rotateX:y*-2.2,duration:.55,ease:'power3.out',overwrite:true,force3D:true});
        if(img) gsap.to(img,{x:x*10,y:y*-8,scale:1.018,duration:.65,ease:'power3.out',overwrite:true,force3D:true});
      }, {passive:true});
      frame.addEventListener('pointerleave', function(){
        gsap.to(frame,{rotateX:0,rotateY:0,duration:.82,ease:'elastic.out(1,.74)',overwrite:true,force3D:true});
        if(img) gsap.to(img,{x:0,y:0,scale:1,duration:.75,ease:'power3.out',overwrite:true,force3D:true});
      }, {passive:true});
    });
    if(window.ScrollTrigger){ try{ window.ScrollTrigger.refresh(); }catch(e){} }
  }
  ready(init);
  window.addEventListener('tabaq:page-change', function(){ window.setTimeout(init, 80); });
})();
/* REV95 — PRODUCT-LED ORDER MOTION END */




/* REV131 — LANDING HERO MOTION WATCHDOG START
   Purpose: verify the landing hero bottle is actually moving. If computed transform does not change, apply the approved Rev127 CSS idle path. This does not create a second renderer, nav, route, or mount. */
(function(){
  function readMotionSnapshot(el){
    if(!el) return '';
    var cs = window.getComputedStyle(el);
    return [cs.transform, cs.animationName, cs.opacity].join('|');
  }
  function verifyHeroBottleMotion(){
    var root = document.documentElement;
    var bottle = document.querySelector('.hero .hero-product');
    if(!root || !bottle) return;
    if(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches){
      root.setAttribute('data-rev131-hero-motion', 'reduced-motion');
      return;
    }
    var first = readMotionSnapshot(bottle);
    window.setTimeout(function(){
      var second = readMotionSnapshot(bottle);
      var moving = first !== second || /rev127HeroBottleIdle/.test(second);
      if(!moving){
        root.classList.add('rev131-hero-motion-repair');
        root.setAttribute('data-rev131-hero-motion', 'repair-css');
      }else{
        root.classList.remove('rev131-hero-motion-repair');
        root.setAttribute('data-rev131-hero-motion', 'verified');
      }
      try{ window.dispatchEvent(new CustomEvent('tabaq:hero-motion-state', {detail:{revision:'131', state:root.getAttribute('data-rev131-hero-motion')}})); }catch(e){}
    }, 760);
  }
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', verifyHeroBottleMotion, {once:true});
  else verifyHeroBottleMotion();
  window.addEventListener('load', verifyHeroBottleMotion, {once:true});
})();
/* REV131 — LANDING HERO MOTION WATCHDOG END */


/* REV134 — HERO ASSET WATCHDOG + VISUAL QA START
   Purpose: verify the landing hero product image is actually decoded and prevent broken-image alt text from weakening the first view. No renderer, route, nav, or motion path is added. */
(function(){
  var PRIMARY_HERO_ASSET='assets/tabaq_asset_004.webp';
  function mark(state){
    var root=document.documentElement;
    root.dataset.rev134QaState='hero-asset-watchdog-visual-qa';
    root.dataset.rev134HeroAsset=state;
    root.dataset.tabaqRevision='146-coming-kit-drop-preview';
    root.dataset.rev140FirstViewRepair='active';
  }
  function imageReady(img){
    return !!(img && img.complete && img.naturalWidth > 8 && img.naturalHeight > 8);
  }
  function runHeroAssetWatchdog(){
    var product=document.querySelector('.hero-product.js-hero-product');
    var orbit=document.querySelector('.product-orbit.js-orbit');
    if(!product){ mark('missing'); return; }
    product.loading='eager';
    product.decoding='async';
    product.setAttribute('fetchpriority','high');
    if(imageReady(product)){
      product.classList.remove('rev134-img-broken');
      if(orbit) orbit.classList.remove('rev134-img-broken');
      mark('loaded');
      return;
    }
    var attemptedRepair=false;
    function failSoft(){
      if(!attemptedRepair && product.getAttribute('src') !== PRIMARY_HERO_ASSET){
        attemptedRepair=true;
        product.src=PRIMARY_HERO_ASSET;
        mark('repairing');
        return;
      }
      if(!imageReady(product)){
        product.classList.add('rev134-img-broken');
        if(orbit) orbit.classList.add('rev134-img-broken');
        mark('fallback-placeholder');
      }
    }
    product.addEventListener('load', function(){
      product.classList.remove('rev134-img-broken');
      if(orbit) orbit.classList.remove('rev134-img-broken');
      mark('loaded');
    }, {once:false});
    product.addEventListener('error', failSoft, {once:false});
    window.setTimeout(function(){
      if(imageReady(product)){ mark('loaded'); }
      else failSoft();
    }, 900);
    window.setTimeout(function(){
      if(!imageReady(product)) failSoft();
    }, 1800);
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded', runHeroAssetWatchdog, {once:true});
  else runHeroAssetWatchdog();
})();
/* REV134 — HERO ASSET WATCHDOG + VISUAL QA END */



/* REV135 — JOYFUL SCROLL CINEMA START
   Purpose: one additive scroll-experience system. It animates the new layer story and updates layer state while preserving the existing shell, renderer, nav, and hero motion. */
(function(){
  var captions=['01 Mist — Lift','02 EDP — Define','03 Oil 01 — Soften','04 Oil 02 — Deepen'];
  function ready(fn){ if(document.readyState==='loading') document.addEventListener('DOMContentLoaded', fn, {once:true}); else fn(); }
  function clamp(v,min,max){ return Math.max(min, Math.min(max, v)); }
  function initRev135ScrollCinema(){
    var root=document.documentElement;
    var cinema=document.querySelector('section[data-rev135-scroll-cinema]');
    if(!cinema || cinema.dataset.rev135Init==='true') return;
    cinema.dataset.rev135Init='true';
    var progressEl=cinema.querySelector('[data-rev135-progress]');
    var steps=[].slice.call(cinema.querySelectorAll('[data-rev135-step]'));
    var bottles=[].slice.call(cinema.querySelectorAll('[data-rev135-layer]'));
    var caption=cinema.querySelector('[data-rev135-caption]');
    var reduced=window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    function setLayer(index){
      index=clamp(index,0,3);
      steps.forEach(function(el,i){ el.classList.toggle('is-active', i===index); });
      bottles.forEach(function(el,i){ el.classList.toggle('is-active', i===index); });
      if(caption) caption.textContent=captions[index];
      cinema.setAttribute('data-rev135-active-layer', String(index+1));
      root.dataset.rev135ActiveLayer=String(index+1);
    }
    function updateByScroll(){
      var rect=cinema.getBoundingClientRect();
      var span=Math.max(rect.height-window.innerHeight,1);
      var progress=clamp((0-rect.top)/span,0,1);
      var layer=clamp(Math.round(progress*3),0,3);
      cinema.style.setProperty('--rev135-progress', String(Math.max(.14, progress)));
      cinema.style.setProperty('--rev135-sun-scale', String(1 + progress*.16));
      setLayer(layer);
    }
    if(window.gsap && window.ScrollTrigger && !reduced){
      try{
        gsap.registerPlugin(ScrollTrigger);
        gsap.to(cinema, {scrollTrigger:{trigger:cinema,start:'top bottom',end:'bottom top',scrub:true,onUpdate:function(self){
          var p=clamp(self.progress,0,1);
          var layer=clamp(Math.round(p*3),0,3);
          cinema.style.setProperty('--rev135-progress', String(Math.max(.14,p)));
          cinema.style.setProperty('--rev135-sun-scale', String(1 + p*.16));
          setLayer(layer);
        }}});
        gsap.fromTo('.rev135-scroll-copy h2',{y:40,opacity:.001},{y:0,opacity:1,duration:.8,ease:'power4.out',scrollTrigger:{trigger:cinema,start:'top 78%',once:true}});
        gsap.fromTo('.rev135-scroll-stage',{y:46,rotateX:3,opacity:.001},{y:0,rotateX:0,opacity:1,duration:.9,ease:'power4.out',scrollTrigger:{trigger:cinema,start:'top 72%',once:true}});
        root.dataset.rev135ScrollCinemaMode='gsap-scrolltrigger';
      }catch(e){
        root.dataset.rev135ScrollCinemaMode='scroll-listener';
        window.addEventListener('scroll', updateByScroll, {passive:true});
        window.addEventListener('resize', updateByScroll, {passive:true});
      }
    }else{
      root.dataset.rev135ScrollCinemaMode=reduced ? 'reduced-motion' : 'css-scroll-listener';
      window.addEventListener('scroll', updateByScroll, {passive:true});
      window.addEventListener('resize', updateByScroll, {passive:true});
    }
    setLayer(0);
    updateByScroll();
    root.dataset.rev135QaState='joyful-scroll-cinema';
  }
  ready(initRev135ScrollCinema);
  window.addEventListener('tabaq:page-change', function(){ window.setTimeout(initRev135ScrollCinema, 80); });
})();
/* REV135 — JOYFUL SCROLL CINEMA END */


/* REV136 — SITEWIDE SCROLL EXPERIENCE START
   Purpose: apply the joyful scroll language across every page through one additive enhancement layer. No new router, renderer, nav, iframe, or substitute mount. */
(function(){
  var phases=[
    {label:'Lift', num:'01'},
    {label:'Define', num:'02'},
    {label:'Soften', num:'03'},
    {label:'Deepen', num:'04'}
  ];
  var REV192_NO_GENERIC_JOURNEY={gallery:true,drop:true};
  var stories={
    home:{k:'Landing ritual',t:'Scroll the kit alive.',d:'The landing page introduces TABAQ as a ready-made fragrance layering system: one mood, four paired products, one clear order.',a:'#ffe76a',b:'#ff7da2',steps:[['01','See','Understand the kit-first idea fast.'],['02','Build','Watch the four layers become a ritual.'],['03','Choose','Move from story to kit selection.'],['04','Join','Save the kit for early access.']]},
    shop:{k:'Shop journey',t:'Choose by mood.',d:'The shop page now reads like a guided choice path: pick a feeling, compare the kits, then join the early line.',a:'#d9f5e8',b:'#ff7da2',steps:[['01','Mood','Fresh, soft, warm or bright.'],['02','Kit','Each kit has four paired products.'],['03','Proof','Compare use, mood and price.'],['04','Action','Open the kit or join the line.']]},
    layering:{k:'Layering guide',t:'Wear in order.',d:'The layering page turns the product sequence into a simple scroll ritual: Mist, Eau de Parfum, Oil 01, Oil 02.',a:'#ffe76a',b:'#9be0bb',steps:[['01','Mist','Lift and prime the skin.'],['02','EDP','Define the scent identity.'],['03','Oil 01','Soften the close layer.'],['04','Oil 02','Deepen or switch the finish.']]},
    gallery:{k:'Lookbook journey',t:'Pick the feel.',d:'The lookbook scroll experience makes mood selection tactile: daily, soft, warm, or bright.',a:'#ffe0ed',b:'#ffec6d',steps:[['01','Daily','Clean Skin for easy wear.'],['02','Soft','Soft Bloom for gentle floral days.'],['03','Warm','Amber Haze for evening.'],['04','Bright','Juice Drift for social energy.']]},
    about:{k:'Proof journey',t:'Less guessing.',d:'The proof page explains why TABAQ exists: loose bottles create doubt; a kit creates a clear wearable routine.',a:'#fff1b8',b:'#b8e9c9',steps:[['01','Problem','Too many separate bottles.'],['02','System','One ready-made kit.'],['03','Order','Every product has a role.'],['04','Trust','The pairing is already done.']]},
    drop:{k:'Drop journey',t:'Join first.',d:'The drop page turns early access into a simple path: pick your kit, join the line, buy when access opens.',a:'#ff7da2',b:'#ffe76a',steps:[['01','Pick','Choose the kit mood.'],['02','Join','Save your place.'],['03','Wait','No payment now.'],['04','Buy','Order when the window opens.']]},
    'product-clean-skin':{k:'Product journey',t:'Clean Skin ritual.',d:'Read the mood, check the four paired products, then join the early line if the daily-clean profile fits.',a:'#d9f5e8',b:'#4bc9ca',steps:[['01','Mood','Fresh, soft, close.'],['02','Layers','Mineral lift to quiet musk.'],['03','Proof','Daily wear and gifting.'],['04','Join','Clean Skin early line.']]},
    'product-soft-bloom':{k:'Product journey',t:'Soft Bloom ritual.',d:'Read the mood, check the four paired products, then join the early line if soft floral is the right finish.',a:'#ffe0ed',b:'#e86e9e',steps:[['01','Mood','Soft, floral, smooth.'],['02','Layers','Petal lift to creamy skin.'],['03','Proof','Gentle floral wear.'],['04','Join','Soft Bloom early line.']]},
    'product-amber-haze':{k:'Product journey',t:'Amber Haze ritual.',d:'Read the mood, check the four paired products, then join the early line if warm evening wear fits.',a:'#ffd9a6',b:'#c77a2e',steps:[['01','Mood','Warm, smooth, rich.'],['02','Layers','Warm air to wooded finish.'],['03','Proof','Evening and colder days.'],['04','Join','Amber Haze early line.']]},
    'product-juice-drift':{k:'Product journey',t:'Juice Drift ritual.',d:'Read the mood, check the four paired products, then join the early line if bright social energy fits.',a:'#ffec6d',b:'#ff4f1e',steps:[['01','Mood','Bright, juicy, social.'],['02','Layers','Citrus spark to clean sweet.'],['03','Proof','Weekend and day plans.'],['04','Join','Juice Drift early line.']]}
  };
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn,{once:true}):fn();}
  function qs(sel,root){return (root||document).querySelector(sel);}
  function qsa(sel,root){return Array.prototype.slice.call((root||document).querySelectorAll(sel));}
  function clamp(v,min,max){return Math.max(min,Math.min(max,v));}
  function activePage(){return qs('.tabaq-page.is-active') || qs('.tabaq-page[data-page="home"]');}
  function storyFor(page){return stories[page] || stories.home;}
  function makeJourney(pageName){
    var story=storyFor(pageName);
    var el=document.createElement('section');
    el.className='rev136-page-journey rev136-scroll-reveal';
    el.setAttribute('aria-label','TABAQ scroll journey for '+pageName.replace(/-/g,' '));
    el.dataset.rev136PageJourney=pageName;
    el.style.setProperty('--rev136-local-a',story.a);
    el.style.setProperty('--rev136-local-b',story.b);
    el.innerHTML='<div class="rev136-page-journey__head"><div><span class="rev136-page-journey__kicker">'+story.k+'</span><h2>'+story.t+'</h2></div><p>'+story.d+'</p></div><div class="rev136-page-journey__steps">'+story.steps.map(function(s,i){return '<button type="button" class="rev136-page-journey__step'+(i===0?' is-active':'')+'" data-rev136-step="'+i+'" data-rev142-layer-jump="'+i+'" aria-label="Jump to layer '+s[0]+' '+s[1]+'"><b>'+s[0]+'</b><strong>'+s[1]+'</strong><span>'+s[2]+'</span></button>';}).join('')+'</div>';
    return el;
  }
  function installJourneys(){
    qsa('.tabaq-page[data-page]').forEach(function(page){
      var name=page.dataset.page;
      if(REV192_NO_GENERIC_JOURNEY[name]){
        var oldJourney=qs('[data-rev136-page-journey="'+name+'"]',page);
        if(oldJourney && oldJourney.parentNode) oldJourney.parentNode.removeChild(oldJourney);
        return;
      }
      if(qs('[data-rev136-page-journey="'+name+'"]',page)) return;
      var journey=makeJourney(name);
      var header=qs(':scope > .page-shell > header',page) || qs(':scope > .page-shell > article',page) || qs(':scope > .hero',page) || qs(':scope > .page-shell',page);
      if(name==='home'){
        var hero=qs('.hero',page);
        if(hero && hero.parentNode) hero.insertAdjacentElement('afterend', journey);
        else page.insertBefore(journey,page.firstElementChild);
      }else if(header && header.parentNode && header.tagName && header.tagName.toLowerCase()==='header'){
        header.insertAdjacentElement('afterend', journey);
      }else{
        var shell=qs(':scope > .page-shell',page);
        if(shell) shell.insertBefore(journey,shell.firstElementChild);
        else page.insertBefore(journey,page.firstElementChild);
      }
    });
    qsa('.tabaq-page section,.tabaq-page article').forEach(function(el){
      if(el.classList.contains('rev136-page-journey') || el.closest('.rev136-page-journey')) return;
      if(!el.classList.contains('rev136-scroll-reveal')) el.classList.add('rev136-scroll-reveal');
    });
  }
  function updateTrail(){
    var root=document.documentElement;
    var page=activePage();
    if(!page) return;
    var pageName=page.dataset.page || 'home';
    var doc=document.documentElement;
    var max=Math.max(doc.scrollHeight-window.innerHeight,1);
    var p=clamp((window.scrollY||window.pageYOffset||0)/max,0,1);
    var idx=clamp(Math.floor(p*4),0,3);
    root.style.setProperty('--rev136-scroll-progress',String(Math.max(.04,p)));
    root.dataset.rev136ActivePage=pageName;
    root.dataset.rev136ScrollPhase=String(idx+1);
    var story=storyFor(pageName);
    root.style.setProperty('--rev136-active-a',story.a);
    root.style.setProperty('--rev136-active-b',story.b);
    var label=qs('[data-rev136-trail-label]');
    if(label) label.textContent=phases[idx].label;
    qsa('[data-rev136-trail-dot]').forEach(function(dot,i){dot.classList.toggle('is-active',i===idx);});
    qsa('[data-rev136-page-journey]',page).forEach(function(journey){
      var rect=journey.getBoundingClientRect();
      var local=clamp((window.innerHeight*.72-rect.top)/Math.max(rect.height,1),0,1);
      var step=clamp(Math.floor(local*4),0,3);
      qsa('[data-rev136-step]',journey).forEach(function(el,i){el.classList.toggle('is-active',i===step);});
    });
  }
  function reveal(){
    var viewH=window.innerHeight||800;
    qsa('.tabaq-page.is-active .rev136-scroll-reveal').forEach(function(el){
      var rect=el.getBoundingClientRect();
      if(rect.top<viewH*.86 && rect.bottom>viewH*.08) el.classList.add('is-inview');
    });
  }
  function tick(){updateTrail();reveal();}
  function boot(){
    installJourneys();
    tick();
    window.addEventListener('scroll',tick,{passive:true});
    window.addEventListener('resize',tick,{passive:true});
    window.addEventListener('tabaq:page-change',function(){window.setTimeout(function(){installJourneys();tick();},80);});
    document.documentElement.dataset.rev136QaState='sitewide-scroll-experience';
  }
  ready(boot);
})();
/* REV136 — SITEWIDE SCROLL EXPERIENCE END */


/* REV137 — SITEWIDE SCROLL CHOREOGRAPHY START
   Purpose: add a coherent, joyful scroll atmosphere and page bridge across all pages without replacing Rev136 journeys.
*/
(function(){
  'use strict';
  var root=document.documentElement;
  var lastY=window.scrollY||0;
  var phases=[
    {label:'Lift',code:'01',a:'#ffe76a',b:'#ff7da2'},
    {label:'Define',code:'02',a:'#ff563f',b:'#ffc857'},
    {label:'Soften',code:'03',a:'#b8e9c9',b:'#f8c8dc'},
    {label:'Deepen',code:'04',a:'#7a4cff',b:'#11100c'}
  ];
  var pageCopy={
    home:['Start here','One mood, four layers, one joyful scroll ritual.'],
    shop:['Choose by mood','Scroll through the kits like a scent menu, then pick the world you want to wear.'],
    layering:['Build the ritual','Mist lifts, EDP defines, Oil 01 softens, Oil 02 deepens the finish.'],
    gallery:['See the mood','Each lookbook world behaves like a finished scent, not a random product grid.'],
    about:['Why it works','TABAQ removes guesswork by pairing products into a complete fragrance system.'],
    drop:['Catch the drop','Follow the layer trail, choose the kit, join the early-access line.']
  };
  ['clean-skin','soft-bloom','amber-haze','juice-drift'].forEach(function(name){
    pageCopy[name]=['Wear the kit','Scroll from Lift to Deepen and understand the complete order before buying.'];
  });
  function qs(s,c){return (c||document).querySelector(s);}
  function qsa(s,c){return Array.prototype.slice.call((c||document).querySelectorAll(s));}
  function clamp(v,min,max){return Math.max(min,Math.min(max,v));}
  function ready(fn){if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',fn,{once:true});else fn();}
  function activePage(){return qs('.tabaq-page.is-active') || qs('.tabaq-page[data-page="home"]');}
  function activeName(){var page=activePage();return page && page.dataset.page ? page.dataset.page : 'home';}
  function bridgeMarkup(name){
    var copy=pageCopy[name]||pageCopy.home;
    return '<div><span class="rev137-page-bridge__kicker">Layered scroll path</span><h3>'+copy[0]+'</h3><p>'+copy[1]+'</p></div><div class="rev137-page-bridge__meter"><span class="rev137-page-bridge__flow" aria-hidden="true"><i data-rev137-bridge-fill></i></span><span class="rev137-page-bridge__beads" role="group" aria-label="Jump between layering stages"><button class="is-active" type="button" data-rev137-bead="0" data-rev142-layer-jump="0" aria-label="Jump to 01 Lift">01</button><button type="button" data-rev137-bead="1" data-rev142-layer-jump="1" aria-label="Jump to 02 Define">02</button><button type="button" data-rev137-bead="2" data-rev142-layer-jump="2" aria-label="Jump to 03 Soften">03</button><button type="button" data-rev137-bead="3" data-rev142-layer-jump="3" aria-label="Jump to 04 Deepen">04</button></span></div>';
  }
  function installBridges(){
    var REV192_NO_GENERIC_BRIDGE={gallery:true,drop:true};
    qsa('.tabaq-page[data-page]').forEach(function(page){
      var name=page.dataset.page||'home';
      if(REV192_NO_GENERIC_BRIDGE[name]){
        var oldBridge=qs('[data-rev137-page-bridge="'+name+'"]',page);
        if(oldBridge && oldBridge.parentNode) oldBridge.parentNode.removeChild(oldBridge);
        return;
      }
      if(qs('[data-rev137-page-bridge="'+name+'"]',page)) return;
      var bridge=document.createElement('section');
      bridge.className='rev137-page-bridge rev136-scroll-reveal';
      bridge.dataset.rev137PageBridge=name;
      bridge.setAttribute('aria-label','TABAQ scroll bridge for '+name.replace(/-/g,' '));
      bridge.innerHTML=bridgeMarkup(name);
      var journey=qs('[data-rev136-page-journey="'+name+'"]',page);
      if(journey && journey.parentNode){journey.parentNode.insertBefore(bridge,journey);return;}
      if(name==='home'){
        var hero=qs('.hero',page);
        if(hero && hero.parentNode){hero.insertAdjacentElement('afterend',bridge);return;}
      }
      var header=qs(':scope > .page-shell > header',page);
      if(header && header.parentNode){header.insertAdjacentElement('afterend',bridge);return;}
      var shell=qs(':scope > .page-shell',page);
      if(shell){shell.insertBefore(bridge,shell.firstElementChild);return;}
      page.insertBefore(bridge,page.firstElementChild);
    });
  }
  function update(){
    var y=window.scrollY||window.pageYOffset||0;
    var doc=document.documentElement;
    var max=Math.max(doc.scrollHeight-window.innerHeight,1);
    var progress=clamp(y/max,0,1);
    var idx=clamp(Math.floor(progress*4),0,3);
    var phase=phases[idx];
    root.style.setProperty('--rev137-progress',String(Math.max(.035,progress)));
    root.style.setProperty('--rev137-phase',String(idx));
    root.style.setProperty('--rev137-a',phase.a);
    root.style.setProperty('--rev137-b',phase.b);
    root.dataset.rev137ScrollPhase=phase.code+'-'+phase.label.toLowerCase();
    root.dataset.rev137ActivePage=activeName();
    root.dataset.rev137ScrollDirection=y>=lastY?'down':'up';
    lastY=y;
    qsa('[data-rev137-page-bridge]').forEach(function(bridge){
      var active=bridge.closest('.tabaq-page.is-active');
      bridge.classList.toggle('is-inview',!!active);
      qsa('[data-rev137-bead]',bridge).forEach(function(bead,i){bead.classList.toggle('is-active',i===idx);});
    });
  }
  function boot(){
    installBridges();
    update();
    window.addEventListener('scroll',update,{passive:true});
    window.addEventListener('resize',update,{passive:true});
    window.addEventListener('tabaq:page-change',function(){window.setTimeout(function(){installBridges();update();},90);});
    root.dataset.rev137QaState='sitewide-scroll-choreography';
    root.dataset.rev137ZipRepair='clean-folder-zip';
  }
  ready(boot);
})();
/* REV137 — SITEWIDE SCROLL CHOREOGRAPHY END */


/* REV138 — COMMERCE ARCHITECTURE FOUNDATION START
   Purpose: standard catalogue cart + checkout readiness + future-drop data model. */
(function(){
  'use strict';
  var root=document.documentElement;
  var STORAGE_KEY='tabaq_rev138_cart';
  var memoryCart={};
  var PRODUCTS={
    'clean-skin':{id:'clean-skin',name:'Clean Skin',price:890,priceLabel:'R890',page:'product-clean-skin',tone:'#d9f5e8',image:'assets/tabaq_asset_005.webp',status:'standard',short:'Fresh daily kit'},
    'soft-bloom':{id:'soft-bloom',name:'Soft Bloom',price:890,priceLabel:'R890',page:'product-soft-bloom',tone:'#ffe0ed',image:'assets/tabaq_asset_008.webp',status:'standard',short:'Soft floral kit'},
    'amber-haze':{id:'amber-haze',name:'Amber Haze',price:950,priceLabel:'R950',page:'product-amber-haze',tone:'#ffd29a',image:'assets/tabaq_asset_009.webp',status:'standard',short:'Warm evening kit'},
    'juice-drift':{id:'juice-drift',name:'Juice Drift',price:890,priceLabel:'R890',page:'product-juice-drift',tone:'#ffe867',image:'assets/tabaq_asset_011.webp',status:'standard',short:'Bright social kit'}
  };
  var DROPS=[
    {id:'future-lift',name:'Future Lift Kit',state:'upcoming'},
    {id:'future-fire-sale',name:'Archive Fire Sale',state:'fire-sale'},
    {id:'future-sold-out',name:'Sold Out Mood Drop',state:'sold-out'}
  ];
  function qs(s,c){return (c||document).querySelector(s);}
  function qsa(s,c){return Array.prototype.slice.call((c||document).querySelectorAll(s));}
  function money(n){return 'R'+String(n||0);}
  function read(){try{return JSON.parse(localStorage.getItem(STORAGE_KEY)||'{}')||{};}catch(e){return Object.assign({},memoryCart);}}
  function write(cart){memoryCart=Object.assign({},cart);try{localStorage.setItem(STORAGE_KEY,JSON.stringify(cart));}catch(e){} render();}
  function count(cart){return Object.keys(cart).reduce(function(a,id){return a+(cart[id]||0);},0);}
  function total(cart){return Object.keys(cart).reduce(function(a,id){return a+((PRODUCTS[id]||{}).price||0)*(cart[id]||0);},0);}
  function openCart(){var cart=qs('[data-rev138-cart]'); if(cart){cart.hidden=false; document.body.classList.add('rev138-cart-open'); render();}}
  function closeCart(){var cart=qs('[data-rev138-cart]'); if(cart){cart.hidden=true; document.body.classList.remove('rev138-cart-open');}}
  function add(id,qty){var p=PRODUCTS[id]; if(!p) return; var cart=read(); cart[id]=(cart[id]||0)+(qty||1); write(cart); root.dataset.rev138LastCartAction='added-'+id; openCart();}
  function setQty(id,qty){var cart=read(); if(qty<=0){delete cart[id];}else{cart[id]=qty;} write(cart);}
  function render(){
    var cart=read();
    var items=qs('[data-rev138-cart-items]');
    var empty=qs('[data-rev138-cart-empty]');
    var totalEl=qs('[data-rev138-cart-total]');
    var c=count(cart);
    qsa('[data-rev138-cart-count]').forEach(function(el){el.textContent=String(c);});
    if(totalEl) totalEl.textContent=money(total(cart));
    if(empty) empty.hidden=c>0;
    if(items){
      items.innerHTML=Object.keys(cart).map(function(id){
        var p=PRODUCTS[id]; if(!p) return '';
        var qty=cart[id]||0;
        return '<article class="rev138-cart-item" data-rev138-cart-line="'+id+'"><img src="'+p.image+'" alt="'+p.name+' kit" style="--tone:'+p.tone+'"><div><b>'+p.name+'</b><span>'+p.short+' · '+p.priceLabel+'</span><div class="rev138-cart-item__qty"><button data-rev138-qty="-1" data-rev138-cart-id="'+id+'" type="button">−</button><strong>'+qty+'</strong><button data-rev138-qty="1" data-rev138-cart-id="'+id+'" type="button">+</button></div></div><strong class="rev138-cart-item__price">'+money(p.price*qty)+'</strong></article>';
      }).join('');
    }
    qsa('[data-rev138-add-cart]').forEach(function(btn){
      var id=btn.getAttribute('data-rev138-add-cart');
      var p=PRODUCTS[id];
      if(!p) return;
      btn.classList.add('rev138-add-cart');
      btn.setAttribute('aria-label','Add '+p.name+' to cart');
      btn.dataset.rev138ProductStatus=p.status;
    });
  }
  function checkout(){
    var cart=read();
    if(!count(cart)){openCart(); var note=qs('[data-rev138-checkout-note]'); if(note) note.textContent='Add a kit first, then checkout/pay can continue.'; return;}
    var note=qs('[data-rev138-checkout-note]');
    if(note) note.textContent='Checkout/pay handoff is staged. Connect this button to Shopify, Stripe, Yoco, Paystack or your selected backend to process real payments.';
    root.dataset.rev138CheckoutState='payment-handoff-ready';
  }
  function annotateStandardCatalogue(){
    Object.keys(PRODUCTS).forEach(function(id){
      qsa('[data-kit-id="'+id+'"], [data-kit-detail="'+id+'"]').forEach(function(el){el.dataset.rev138Standard='true';});
    });
    qsa('[data-rev138-add-cart]').forEach(function(btn){
      var id=btn.getAttribute('data-rev138-add-cart'); var p=PRODUCTS[id]; if(!p) return;
      if(!/Add to cart/i.test(btn.textContent)) btn.textContent='Add to cart — '+p.priceLabel;
    });
  }
  function bind(){
    annotateStandardCatalogue();
    render();
    document.addEventListener('click',function(event){
      var addBtn=event.target.closest&&event.target.closest('[data-rev138-add-cart]');
      if(addBtn){event.preventDefault();event.stopPropagation();add(addBtn.getAttribute('data-rev138-add-cart'),1);return;}
      var open=event.target.closest&&event.target.closest('[data-rev138-open-cart]');
      if(open){event.preventDefault();openCart();return;}
      var close=event.target.closest&&event.target.closest('[data-rev138-close-cart]');
      if(close || event.target.matches('[data-rev138-cart]')){event.preventDefault();closeCart();return;}
      var qty=event.target.closest&&event.target.closest('[data-rev138-qty]');
      if(qty){event.preventDefault();var id=qty.getAttribute('data-rev138-cart-id');var delta=parseInt(qty.getAttribute('data-rev138-qty'),10)||0;var cart=read();setQty(id,(cart[id]||0)+delta);return;}
      var pay=event.target.closest&&event.target.closest('[data-rev138-checkout]');
      if(pay){event.preventDefault();checkout();return;}
    },true);
    window.addEventListener('storage',render);
    window.addEventListener('hashchange',function(){window.setTimeout(function(){annotateStandardCatalogue();render();},80);});
    window.addEventListener('tabaq:page-change',function(){window.setTimeout(function(){annotateStandardCatalogue();render();},80);});
    root.dataset.rev138QaState='commerce-architecture-foundation';
    root.dataset.rev138Products=String(Object.keys(PRODUCTS).length);
    root.dataset.rev138DropStates='upcoming,live,fire-sale,sold-out,ended,archived';
    window.TABAQ_REV138_COMMERCE={products:PRODUCTS,drops:DROPS,add:add,readCart:read,openCart:openCart};
  }
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',bind,{once:true});else bind();
})();
/* REV138 — COMMERCE ARCHITECTURE FOUNDATION END */


/* REV139 — CINEMATIC SCROLL + COMMERCE POLISH START
   Purpose: deepen transitions between existing scroll sections and polish Rev138 cart states. It does not create a renderer, route, nav system, drawer replacement, or payment processor. */
(function(){
  'use strict';
  var root=document.documentElement;
  var layerNames=['Lift','Define','Soften','Deepen'];
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn,{once:true}):fn();}
  function qsa(sel,ctx){return Array.prototype.slice.call((ctx||document).querySelectorAll(sel));}
  function qs(sel,ctx){return (ctx||document).querySelector(sel);}
  function clamp(n,min,max){return Math.max(min,Math.min(max,n));}
  function activePage(){return qs('.tabaq-page.is-active') || qs('.tabaq-page[data-page="home"]');}
  function markRevision(){
    root.dataset.tabaqRevision='146-coming-kit-drop-preview';
    root.dataset.rev140FirstViewRepair='active';
    root.dataset.rev139QaState='cinematic-scroll-commerce-polish';
  }
  function sceneCandidates(page){
    if(!page) return [];
    var selectors=[
      '.hero', '.rev135-scroll-cinema', '.rev138-commerce-foundation', '.rev138-drop-engine',
      '.rev136-page-journey', '.rev137-page-bridge', '.product-grid', '.rev94-drop-grid',
      '.page-hero', '.rev47-routine-strip', '.rev47-sales-intro', '.rev63-grid', '.rev84-motion-card',
      '.rev43-detail-page', '.rev138-commerce-mode'
    ];
    var found=[];
    selectors.forEach(function(sel){qsa(sel,page).forEach(function(el){if(found.indexOf(el)<0) found.push(el);});});
    return found.filter(function(el){return !el.closest('.rev138-cart') && !el.classList.contains('rev139-cinema-scene');});
  }
  function installSceneTags(){
    qsa('.tabaq-page[data-page]').forEach(function(page){
      sceneCandidates(page).forEach(function(el,idx){
        el.classList.add('rev139-cinema-scene');
        el.dataset.rev139Scene=String(idx+1);
        if(!qs(':scope > .rev139-scene-tag',el)){
          var tag=document.createElement('span');
          tag.className='rev139-scene-tag';
          tag.setAttribute('aria-hidden','true');
          tag.textContent=(idx%4+1).toString().padStart(2,'0')+' '+layerNames[idx%4];
          el.insertBefore(tag,el.firstChild);
        }
      });
    });
  }
  var observer=null;
  function observeScenes(){
    if(observer && observer.disconnect) observer.disconnect();
    observer=null;
    var scenes=qsa('.tabaq-page.is-active .rev139-cinema-scene');
    if('IntersectionObserver' in window){
      observer=new IntersectionObserver(function(entries){
        entries.forEach(function(entry){
          var on=entry.isIntersecting && entry.intersectionRatio>.14;
          entry.target.classList.toggle('is-rev139-active',on);
          if(on){root.dataset.rev139ActiveScene=entry.target.dataset.rev139Scene||'1';}
        });
      },{threshold:[.14,.32,.56],rootMargin:'-12% 0px -24% 0px'});
      scenes.forEach(function(el){observer.observe(el);});
    }else{
      scenes.forEach(function(el){el.classList.add('is-rev139-active');});
    }
  }
  function updateScrollCinema(){
    var doc=document.documentElement;
    var max=Math.max(doc.scrollHeight-window.innerHeight,1);
    var progress=clamp((window.scrollY||window.pageYOffset||0)/max,0,1);
    var phase=clamp(Math.floor(progress*4),0,3);
    var colors=[['#ffe76a','#ff7da2'],['#ff7da2','#ffb84d'],['#b8f2d3','#ffe76a'],['#ffb84d','#11100c']][phase];
    root.style.setProperty('--rev139-progress',String(Math.max(.035,progress)));
    root.style.setProperty('--rev139-cinema-a',colors[0]);
    root.style.setProperty('--rev139-cinema-b',colors[1]);
    root.dataset.rev139ScrollPhase=String(phase+1)+'-'+layerNames[phase].toLowerCase();
  }
  function cartQty(){
    var count=qs('[data-rev138-cart-count]');
    return count?parseInt(count.textContent||'0',10)||0:0;
  }
  function setCartStage(stage){
    root.dataset.rev139CartStage=stage;
    qsa('[data-rev139-cart-step]').forEach(function(step){
      var name=step.getAttribute('data-rev139-cart-step');
      var active=(stage==='choose'&&name==='choose') || (stage==='cart'&&(name==='choose'||name==='cart')) || (stage==='pay'&&(name==='choose'||name==='cart'||name==='pay')) || (stage==='wear');
      step.classList.toggle('is-active',active);
    });
  }
  function pulseCart(stage){
    setCartStage(stage);
    document.body.classList.add('rev139-cart-pulse');
    window.clearTimeout(window.__rev139CartPulse);
    window.__rev139CartPulse=window.setTimeout(function(){document.body.classList.remove('rev139-cart-pulse');},760);
  }
  function bindCommercePolish(){
    setCartStage(cartQty()>0?'cart':'choose');
    document.addEventListener('click',function(event){
      var add=event.target.closest&&event.target.closest('[data-rev138-add-cart]');
      if(add){window.setTimeout(function(){pulseCart('cart');},40);}
      var open=event.target.closest&&event.target.closest('[data-rev138-open-cart]');
      if(open){window.setTimeout(function(){setCartStage(cartQty()>0?'cart':'choose');},40);}
      var pay=event.target.closest&&event.target.closest('[data-rev138-checkout]');
      if(pay){window.setTimeout(function(){document.body.classList.add('rev139-pay-ready');setCartStage('pay');},60);}
      var close=event.target.closest&&event.target.closest('[data-rev138-close-cart]');
      if(close){document.body.classList.remove('rev139-pay-ready');}
    },true);
  }
  function boot(){
    markRevision();
    installSceneTags();
    observeScenes();
    updateScrollCinema();
    bindCommercePolish();
    window.addEventListener('scroll',updateScrollCinema,{passive:true});
    window.addEventListener('resize',function(){updateScrollCinema();observeScenes();},{passive:true});
    window.addEventListener('tabaq:page-change',function(){window.setTimeout(function(){markRevision();installSceneTags();observeScenes();updateScrollCinema();},120);});
    window.setTimeout(function(){markRevision();installSceneTags();observeScenes();updateScrollCinema();},500);
  }
  ready(boot);
})();
/* REV139 — CINEMATIC SCROLL + COMMERCE POLISH END */


/* REV139 — COMMERCE COPY CORRECTION START
   Purpose: prevent old Rev75 buying-language guard from weakening the current standard sales checkout/pay path. */
(function(){
  function restoreCheckoutCopy(){
    var pay=document.querySelector('[data-rev138-checkout]');
    if(pay) pay.textContent='Checkout / Pay';
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded', restoreCheckoutCopy, {once:true}); else restoreCheckoutCopy();
  window.addEventListener('tabaq:page-change', function(){window.setTimeout(restoreCheckoutCopy,70);});
  window.setTimeout(restoreCheckoutCopy,500);
  window.setTimeout(restoreCheckoutCopy,1800);
})();
/* REV139 — COMMERCE COPY CORRECTION END */


/* REV140 — FIRST VIEW SCROLL PURPOSE REPAIR START
   Purpose: assert current revision state and add a lightweight scroll-purpose label without changing routing, renderer, nav, hero, or cart behavior.
*/
(function(){
  var root=document.documentElement;
  var body=document.body;
  if(!root||!body) return;
  root.dataset.tabaqRevision='146-coming-kit-drop-preview';
  root.dataset.rev140FirstViewRepair='active';
  body.dataset.tabaqRevision='146-coming-kit-drop-preview';
  body.dataset.rev140QaState='first-view-scroll-purpose-repair';
  body.dataset.rev141QaState='interactive-layer-controls';

  function guardHeroImageAltText(){
    document.querySelectorAll('.hero img').forEach(function(img){
      img.setAttribute('data-rev140-image-guard','true');
      img.addEventListener('error',function(){ img.classList.add('rev140-img-failed'); },{once:false});
      window.setTimeout(function(){
        if(img.complete && img.naturalWidth < 8) img.classList.add('rev140-img-failed');
      },1100);
      window.setTimeout(function(){
        if(img.complete && img.naturalWidth < 8) img.classList.add('rev140-img-failed');
      },2200);
    });
  }

  function ensurePurpose(){
    if(document.querySelector('[data-rev140-scroll-purpose]')) return;
    var trail=document.querySelector('[data-rev136-site-trail]');
    if(!trail) return;
    var purpose=document.createElement('div');
    purpose.className='rev140-scroll-purpose';
    purpose.setAttribute('data-rev140-scroll-purpose','true');
    purpose.setAttribute('aria-hidden','true');
    purpose.innerHTML='<strong>Scroll builds the scent</strong><span>Lift → Define → Soften → Deepen</span>';
    trail.insertAdjacentElement('afterend', purpose);
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',function(){ensurePurpose();guardHeroImageAltText();},{once:true});
  else {ensurePurpose();guardHeroImageAltText();}
})();
/* REV140 — FIRST VIEW SCROLL PURPOSE REPAIR END */


/* REV141 — SCROLL PURPOSE DIRECTOR START
   Purpose: make the scroll experience self-explaining by updating a visible director with the active scent layer.
   One purpose only: guide scroll meaning. No renderer, no nav, no cart, no route replacement.
*/
(function(){
  var root=document.documentElement;
  var body=document.body;
  var phases=[
    {title:'01 Lift', short:'Lift', copy:'Start with Body Mist. Scroll begins the kit with a bright first layer.', a:'#ffe76a', b:'#ff7da2'},
    {title:'02 Define', short:'Define', copy:'Add Eau de Parfum. The main scent identity becomes clear.', a:'#ff7da2', b:'#ffb84d'},
    {title:'03 Soften', short:'Soften', copy:'Oil 01 warms the scent and brings it closer to skin.', a:'#b8f2d3', b:'#ffe76a'},
    {title:'04 Deepen', short:'Deepen', copy:'Oil 02 changes the finish, so the same kit can shift mood.', a:'#ffb84d', b:'#11100c'}
  ];
  function qs(s,ctx){return (ctx||document).querySelector(s);}
  function qsa(s,ctx){return Array.prototype.slice.call((ctx||document).querySelectorAll(s));}
  function clamp(n,min,max){return Math.max(min,Math.min(max,n));}
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn,{once:true}):fn();}
  function activePage(){return qs('.tabaq-page.is-active') || qs('.tabaq-page[data-page="home"]') || document.body;}
  function pageProgress(){
    var page=activePage();
    var rect=page.getBoundingClientRect();
    var total=Math.max(rect.height-window.innerHeight,1);
    return clamp((0-rect.top)/total,0,1);
  }
  function markCurrentRevision(){
    root.dataset.tabaqRevision='146-coming-kit-drop-preview';
    root.dataset.rev141ScrollDirector='active';
    if(body){body.dataset.tabaqRevision='146-coming-kit-drop-preview';body.dataset.rev141QaState='interactive-layer-controls';}
  }
  function updateRev150LayerPanelVisibility(){
    var page=activePage();
    var pageName=(page && page.getAttribute && page.getAttribute('data-page')) || '';
    var keepVisible=pageName==='home' || pageName==='layering';
    root.dataset.rev150LayerPanel=keepVisible ? 'visible' : 'hidden';
  }
  function updateDirector(){
    markCurrentRevision();
    updateRev150LayerPanelVisibility();
    var p=pageProgress();
    var idx=clamp(Math.floor(p*4),0,3);
    var phase=phases[idx];
    root.style.setProperty('--rev141-phase',String(idx));
    root.style.setProperty('--rev141-a',phase.a);
    root.style.setProperty('--rev141-b',phase.b);
    root.dataset.rev141ActiveLayer=phase.short.toLowerCase();
    var title=qs('[data-rev141-director-title]');
    var copy=qs('[data-rev141-director-copy]');
    if(title) title.textContent=phase.title;
    if(copy) copy.textContent=phase.copy;
    qsa('[data-rev141-director-dot]').forEach(function(dot){
      dot.classList.toggle('is-active', String(idx)===dot.getAttribute('data-rev141-director-dot'));
    });
    qsa('[data-rev136-trail-dot]').forEach(function(dot){
      dot.classList.toggle('is-active', String(idx)===dot.getAttribute('data-rev136-trail-dot'));
    });
    var label=qs('[data-rev136-trail-label]');
    if(label) label.textContent=phase.short;
  }
  function boot(){
    markCurrentRevision();
    updateDirector();
    window.addEventListener('scroll', updateDirector, {passive:true});
    window.addEventListener('resize', updateDirector, {passive:true});
    window.addEventListener('tabaq:page-change', function(){updateRev150LayerPanelVisibility();window.setTimeout(updateDirector,80);window.setTimeout(updateDirector,420);});
    window.setTimeout(updateDirector,150);
    window.setTimeout(updateDirector,900);
    window.setTimeout(updateDirector,1700);
    window.setTimeout(updateDirector,2600);
  }
  ready(boot);
})();
/* REV141 — SCROLL PURPOSE DIRECTOR END */


/* REV142 — INTERACTIVE LAYER CONTROLS START
   Purpose: remove dead CTA-looking controls. Layer chips/dots now jump to the relevant layer stage on the active page.
   No renderer, route, nav, cart, or visual-system replacement.
*/
(function(){
  'use strict';
  var root=document.documentElement;
  var body=document.body;
  var TARGETS=[0.03,0.34,0.64,0.92];
  function qs(s,c){return (c||document).querySelector(s);}
  function qsa(s,c){return Array.prototype.slice.call((c||document).querySelectorAll(s));}
  function clamp(v,min,max){return Math.max(min,Math.min(max,v));}
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn,{once:true}):fn();}
  function activePage(){return qs('.tabaq-page.is-active') || qs('.tabaq-page[data-page="home"]') || document.body;}
  function pageTop(page){return (page.getBoundingClientRect().top || 0) + (window.scrollY || window.pageYOffset || 0);}
  function activate(index){
    index=clamp(Number(index)||0,0,3);
    qsa('[data-rev142-layer-jump]').forEach(function(el){
      el.classList.toggle('is-active', Number(el.getAttribute('data-rev142-layer-jump'))===index);
      if(Number(el.getAttribute('data-rev142-layer-jump'))===index) el.setAttribute('aria-current','step');
      else el.removeAttribute('aria-current');
    });
    root.dataset.rev142LastLayerJump=String(index+1);
  }
  function jumpToLayer(index){
    index=clamp(Number(index)||0,0,3);
    var page=activePage();
    var top=pageTop(page);
    var travel=Math.max(page.scrollHeight-window.innerHeight,0);
    var target=top + travel*TARGETS[index];
    activate(index);
    root.dataset.rev142ControlAction='jump-'+String(index+1);
    window.scrollTo({top:Math.max(0,target),behavior:'smooth'});
    window.setTimeout(function(){activate(index);},120);
    window.setTimeout(function(){activate(index);},520);
  }
  function bindControls(){
    qsa('[data-rev142-layer-jump]').forEach(function(el){
      if(el.dataset.rev142Bound==='true') return;
      el.dataset.rev142Bound='true';
      if(!el.hasAttribute('type') && el.tagName.toLowerCase()==='button') el.setAttribute('type','button');
      el.addEventListener('click',function(ev){
        ev.preventDefault();
        ev.stopPropagation();
        jumpToLayer(el.getAttribute('data-rev142-layer-jump'));
      },false);
    });
    root.dataset.rev142InteractiveControls=String(qsa('[data-rev142-layer-jump]').length);
    if(body){body.dataset.rev142QaState='interactive-layer-controls';body.dataset.tabaqRevision='146-coming-kit-drop-preview';}
    root.dataset.tabaqRevision='146-coming-kit-drop-preview';
  }
  function syncFromScroll(){
    var phase=root.dataset.rev136ScrollPhase || '1';
    var idx=clamp((parseInt(phase,10)||1)-1,0,3);
    activate(idx);
  }
  function boot(){
    bindControls();
    syncFromScroll();
    window.addEventListener('scroll',syncFromScroll,{passive:true});
    window.addEventListener('tabaq:page-change',function(){window.setTimeout(bindControls,90);window.setTimeout(syncFromScroll,160);});
    window.setTimeout(bindControls,400);
    window.setTimeout(bindControls,1100);
  }
  ready(boot);
})();
/* REV142 — INTERACTIVE LAYER CONTROLS END */


/* REV143 — PRODUCT UTILITY STUDIO START
   Purpose: turn high-design product discovery into a useful product decision flow: mood -> kit -> layer proof -> view/add to cart. No renderer, route, nav, or cart replacement. */
(function(){
  'use strict';
  var root=document.documentElement;
  var body=document.body;
  var KITS={
    'clean-skin':{n:'01',name:'Clean Skin',mood:'Fresh / soft / daily',price:'R890',page:'product-clean-skin',img:'assets/tabaq_asset_005.webp',copy:'Fresh, soft and easy to wear every day.'},
    'soft-bloom':{n:'02',name:'Soft Bloom',mood:'Soft / floral / gentle',price:'R890',page:'product-soft-bloom',img:'assets/tabaq_asset_008.webp',copy:'A polished soft floral kit: petal, powder and cream without heavy scent.'},
    'amber-haze':{n:'03',name:'Amber Haze',mood:'Warm / smooth / evening',price:'R950',page:'product-amber-haze',img:'assets/tabaq_asset_009.webp',copy:'Warm and smooth. Best for evening and colder days.'},
    'juice-drift':{n:'04',name:'Juice Drift',mood:'Bright / juicy / social',price:'R890',page:'product-juice-drift',img:'assets/tabaq_asset_011.webp',copy:'Bright and juicy. Best for weekends and social days.'}
  };
  function qs(s,c){return (c||document).querySelector(s);}
  function qsa(s,c){return Array.prototype.slice.call((c||document).querySelectorAll(s));}
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn,{once:true}):fn();}
  function safeKit(id){return KITS[id] ? id : 'clean-skin';}
  function setLink(el,kit){if(!el||!kit)return;el.setAttribute('href','#'+kit.page);el.setAttribute('data-page-link',kit.page);}
  function setCart(el,id,kit){if(!el||!kit)return;el.setAttribute('data-rev138-add-cart',id);el.textContent='Add to cart — '+kit.price;el.setAttribute('aria-label','Add '+kit.name+' to cart');}
  function updateStudio(id){
    id=safeKit(id); var kit=KITS[id]; var studio=qs('[data-rev143-kit-studio]'); if(!studio) return;
    studio.dataset.activeKit=id;
    qsa('[data-rev143-kit-choice]',studio).forEach(function(btn){btn.classList.toggle('is-active',btn.getAttribute('data-rev143-kit-choice')===id);btn.setAttribute('aria-pressed',btn.getAttribute('data-rev143-kit-choice')===id?'true':'false');});
    var img=qs('[data-rev143-kit-image]',studio); if(img){img.src=kit.img;img.alt=kit.name+' kit preview';}
    var num=qs('[data-rev143-kit-number]',studio); if(num) num.textContent=kit.n;
    var name=qs('[data-rev143-kit-name]',studio); if(name) name.textContent=kit.name;
    var mood=qs('[data-rev143-kit-mood]',studio); if(mood) mood.textContent=kit.mood;
    var price=qs('[data-rev143-kit-price]',studio); if(price) price.textContent=kit.price;
    setLink(qs('[data-rev143-view-link]',studio),kit);
    var view=qs('[data-rev143-view-link]',studio); if(view) view.textContent='View '+kit.name;
    setCart(qs('[data-rev143-add-cart]',studio),id,kit);
    root.dataset.rev143ActiveKit=id;
  }
  function updateFinder(id){
    id=safeKit(id); var kit=KITS[id]; var result=qs('[data-rev61-finder-result]'); if(!result) return;
    result.dataset.rev143FinderKit=id;
    var title=result.querySelector('strong'); if(title) title.textContent=kit.name;
    var copy=result.querySelector('p'); if(copy) copy.textContent=kit.copy;
    var link=result.querySelector('[data-rev61-result-link]'); setLink(link,kit); if(link) link.textContent='View '+kit.name;
    var img=qs('[data-rev143-finder-image]',result); if(img){img.src=kit.img;img.alt=kit.name+' kit preview';}
    setCart(qs('[data-rev143-finder-cart]',result),id,kit);
  }
  function bind(){
    qsa('[data-rev143-kit-choice]').forEach(function(btn){
      if(btn.dataset.rev143Bound==='true') return;
      btn.dataset.rev143Bound='true';
      btn.setAttribute('aria-pressed',btn.classList.contains('is-active')?'true':'false');
      btn.addEventListener('click',function(){updateStudio(btn.getAttribute('data-rev143-kit-choice'));});
    });
    qsa('[data-rev61-kit]').forEach(function(btn){
      if(btn.dataset.rev143FinderBound==='true') return;
      btn.dataset.rev143FinderBound='true';
      btn.addEventListener('click',function(){
        var page=btn.getAttribute('data-rev61-link')||'product-clean-skin';
        var id=page.replace('product-','');
        window.setTimeout(function(){updateFinder(id);},20);
      });
    });
    updateStudio(root.dataset.rev143ActiveKit||'clean-skin');
    updateFinder('clean-skin');
    root.dataset.rev143ProductUtility='active';
    root.dataset.tabaqRevision='146-coming-kit-drop-preview';
    if(body){body.dataset.rev143QaState='product-utility-studio';body.dataset.tabaqRevision='146-coming-kit-drop-preview';}
  }
  ready(function(){bind();window.addEventListener('tabaq:page-change',function(){window.setTimeout(bind,80);});});
})();
/* REV143 — PRODUCT UTILITY STUDIO END */


/* REV144 — PRODUCT CARD + CART THEATRE START
   Purpose: make product cards clearly interactive and make add-to-cart feel like a polished ritual confirmation. No renderer, route, nav, cart, or payment replacement. */
(function(){
  'use strict';
  var root=document.documentElement;
  var body=document.body;
  var fallbackProducts={
    'clean-skin':{name:'Clean Skin',priceLabel:'R890',tone:'rgba(217,245,232,.72)',short:'Fresh daily kit',page:'product-clean-skin'},
    'soft-bloom':{name:'Soft Bloom',priceLabel:'R890',tone:'rgba(255,224,237,.72)',short:'Soft floral kit',page:'product-soft-bloom'},
    'amber-haze':{name:'Amber Haze',priceLabel:'R950',tone:'rgba(255,210,154,.72)',short:'Warm evening kit',page:'product-amber-haze'},
    'juice-drift':{name:'Juice Drift',priceLabel:'R890',tone:'rgba(255,232,103,.72)',short:'Bright social kit',page:'product-juice-drift'}
  };
  function qs(s,c){return (c||document).querySelector(s);}
  function qsa(s,c){return Array.prototype.slice.call((c||document).querySelectorAll(s));}
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn,{once:true}):fn();}
  function products(){return (window.TABAQ_REV138_COMMERCE&&window.TABAQ_REV138_COMMERCE.products)||fallbackProducts;}
  function product(id){return products()[id]||fallbackProducts[id]||fallbackProducts['clean-skin'];}
  function routeTo(page){
    if(!page)return;
    if(window.TABAQ&&typeof window.TABAQ.setPage==='function'){window.TABAQ.setPage(page);return;}
    window.location.hash='#'+page;
  }
  function cardRoute(card){
    var explicit=card.getAttribute('data-rev144-card-route');
    if(explicit)return explicit;
    var id=card.getAttribute('data-kit-id')||card.getAttribute('data-kit-detail')||'';
    if(id && fallbackProducts[id]) return fallbackProducts[id].page;
    var link=qs('[data-page-link]',card);
    return link?link.getAttribute('data-page-link'):'';
  }
  function addCue(card){
    if(qs('.rev144-card-cue',card))return;
    var cue=document.createElement('span');
    cue.className='rev144-card-cue';
    cue.textContent='View kit';
    card.appendChild(cue);
  }
  function annotateCards(){
    qsa('.product-card[data-kit-id]').forEach(function(card){
      if(card.dataset.rev144CardReady==='true')return;
      var route=cardRoute(card);
      card.dataset.rev144CardReady='true';
      card.dataset.rev144CardRoute=route;
      card.setAttribute('tabindex','0');
      card.setAttribute('role','button');
      var name=card.getAttribute('data-kit-name')||card.getAttribute('data-kit-id')||'kit';
      card.setAttribute('aria-label','View '+name+' kit details');
      addCue(card);
      card.addEventListener('pointermove',function(event){
        var rect=card.getBoundingClientRect();
        if(!rect.width||!rect.height)return;
        var x=((event.clientX-rect.left)/rect.width)*100;
        var y=((event.clientY-rect.top)/rect.height)*100;
        var tiltX=((x-50)/50)*-2.2;
        var tiltY=((y-50)/50)*1.8;
        card.style.setProperty('--rev144-x',x.toFixed(1)+'%');
        card.style.setProperty('--rev144-y',y.toFixed(1)+'%');
        card.style.setProperty('--rev144-tilt-x',tiltX.toFixed(2)+'deg');
        card.style.setProperty('--rev144-tilt-y',tiltY.toFixed(2)+'deg');
      },{passive:true});
      card.addEventListener('pointerleave',function(){
        card.style.removeProperty('--rev144-tilt-x');
        card.style.removeProperty('--rev144-tilt-y');
      },{passive:true});
      card.addEventListener('focus',function(){card.classList.add('is-rev144-card-focus');});
      card.addEventListener('blur',function(){card.classList.remove('is-rev144-card-focus');});
      card.addEventListener('click',function(event){
        if(event.target.closest('a,button,[data-rev138-add-cart],[data-kit-toggle]'))return;
        routeTo(card.dataset.rev144CardRoute);
      });
      card.addEventListener('keydown',function(event){
        if(event.key!=='Enter'&&event.key!==' ')return;
        if(document.activeElement!==card)return;
        event.preventDefault();
        routeTo(card.dataset.rev144CardRoute);
      });
    });
  }
  function theatre(){return qs('[data-rev144-cart-theatre]');}
  function updateTheatre(id){
    var panel=theatre(); if(!panel)return;
    var p=product(id);
    panel.dataset.rev144CartTheatreState='added';
    panel.style.setProperty('--rev144-cart-tone',p.tone||'rgba(255,231,101,.55)');
    var eyebrow=qs('[data-rev144-cart-eyebrow]',panel); if(eyebrow)eyebrow.textContent='Kit added';
    var title=qs('[data-rev144-cart-title]',panel); if(title)title.textContent=p.name+' is in your cart.';
    var copy=qs('[data-rev144-cart-copy]',panel); if(copy)copy.textContent='Complete four-product kit added. Review quantity, then continue to checkout/pay.';
    qsa('[data-rev144-cart-theatre] .rev144-cart-theatre__layers span').forEach(function(layer,i){
      layer.classList.toggle('is-active',i===0);
      window.setTimeout(function(){layer.classList.add('is-active');},120+(i*80));
    });
    window.clearTimeout(window.__rev144CartTheatreReset);
    window.__rev144CartTheatreReset=window.setTimeout(function(){panel.dataset.rev144CartTheatreState='settled';},980);
  }
  function pulseButton(btn){
    if(!btn)return;
    btn.classList.remove('rev144-just-added');
    void btn.offsetWidth;
    btn.classList.add('rev144-just-added');
    window.setTimeout(function(){btn.classList.remove('rev144-just-added');},920);
  }
  function pulseShell(){
    if(!body)return;
    body.classList.add('rev144-cart-theatre-pulse');
    window.clearTimeout(window.__rev144CartPulse);
    window.__rev144CartPulse=window.setTimeout(function(){body.classList.remove('rev144-cart-theatre-pulse');},980);
  }
  function bind(){
    annotateCards();
    document.addEventListener('click',function(event){
      var add=event.target.closest&&event.target.closest('[data-rev138-add-cart]');
      if(!add)return;
      var id=add.getAttribute('data-rev138-add-cart');
      window.setTimeout(function(){updateTheatre(id);pulseButton(add);pulseShell();},60);
    },true);
    window.addEventListener('tabaq:page-change',function(){window.setTimeout(annotateCards,120);});
    root.dataset.rev144QaState='product-card-cart-theatre';
    root.dataset.tabaqRevision='146-coming-kit-drop-preview';
    if(body){body.dataset.rev144QaState='product-card-cart-theatre';body.dataset.tabaqRevision='146-coming-kit-drop-preview';}
  }
  ready(bind);
})();
/* REV144 — PRODUCT CARD + CART THEATRE END */


/* REV145 — SCENT DECISION LENS START
   Purpose: useful product decision interaction. Does not replace cart/router; it updates the lens, highlights the matching card, and reuses Rev138 add-to-cart. */
(function(){
  var root=document.documentElement;
  var body=document.body;
  var kits={
    'clean-skin':{name:'Clean Skin',mood:'Daily clean',copy:'Fresh, soft and easy to wear every day. Best first kit for clean daily wear.',use:'Work · travel · gifting',finish:'Soft close skin',price:'R890',tone:'#d9f5e8',img:'assets/tabaq_asset_005.webp',route:'product-clean-skin'},
    'soft-bloom':{name:'Soft Bloom',mood:'Soft floral',copy:'A polished floral kit: petal, powder and cream without heavy scent.',use:'Brunch · dates · gifting',finish:'Powder-soft floral',price:'R890',tone:'#ffe0ed',img:'assets/tabaq_asset_008.webp',route:'product-soft-bloom'},
    'amber-haze':{name:'Amber Haze',mood:'Warm evening',copy:'Warm, smooth and evening-ready. Best when the day needs depth.',use:'Dinner · night · winter',finish:'Warm resin skin',price:'R950',tone:'#ffd29a',img:'assets/tabaq_asset_009.webp',route:'product-amber-haze'},
    'juice-drift':{name:'Juice Drift',mood:'Bright social',copy:'Bright, juicy and playful. Built for weekends, summer and social energy.',use:'Weekends · summer · day plans',finish:'Juicy clean sweetness',price:'R890',tone:'#ffe867',img:'assets/tabaq_asset_011.webp',route:'product-juice-drift'}
  };
  function qs(sel,ctx){return (ctx||document).querySelector(sel);}
  function qsa(sel,ctx){return Array.prototype.slice.call((ctx||document).querySelectorAll(sel));}
  function setText(sel,val,ctx){var el=qs(sel,ctx); if(el)el.textContent=val;}
  function applyLens(id){
    var lens=qs('[data-rev145-scent-lens]');
    var data=kits[id]||kits['clean-skin'];
    if(!lens)return;
    var stage=qs('[data-rev145-lens-stage]',lens);
    if(stage){
      stage.classList.add('is-switching');
      stage.style.setProperty('--rev145-tone',data.tone);
      window.setTimeout(function(){stage.classList.remove('is-switching');},220);
    }
    var img=qs('[data-rev145-lens-image]',lens);
    if(img){img.src=data.img; img.alt=data.name+' kit preview';}
    setText('[data-rev145-lens-mood]',data.mood,lens);
    setText('[data-rev145-lens-name]',data.name,lens);
    setText('[data-rev145-lens-copy]',data.copy,lens);
    setText('[data-rev145-lens-use]',data.use,lens);
    setText('[data-rev145-lens-finish]',data.finish,lens);
    setText('[data-rev145-lens-price]',data.price,lens);
    var link=qs('[data-rev145-lens-link]',lens);
    if(link){link.href='#'+data.route; link.setAttribute('data-page-link',data.route); link.textContent='View '+data.name;}
    var cart=qs('[data-rev145-lens-cart]',lens);
    if(cart){cart.setAttribute('data-rev138-add-cart',id); cart.textContent='Add to cart — '+data.price;}
    qsa('[data-rev145-lens-choice]',lens).forEach(function(btn){
      var active=btn.getAttribute('data-rev145-lens-choice')===id;
      btn.classList.toggle('is-active',active);
      btn.setAttribute('aria-pressed',active?'true':'false');
    });
    qsa('.product-card[data-kit-id]').forEach(function(card){card.classList.toggle('rev145-lens-selected',card.getAttribute('data-kit-id')===id);});
    if(root){root.dataset.rev145ActiveKit=id;}
  }
  function init(){
    var lens=qs('[data-rev145-scent-lens]');
    if(!lens)return;
    qsa('[data-rev145-lens-choice]',lens).forEach(function(btn){
      btn.addEventListener('click',function(){applyLens(btn.getAttribute('data-rev145-lens-choice'));});
    });
    applyLens('clean-skin');
    if(root){root.dataset.rev145QaState='scent-decision-lens';root.dataset.tabaqRevision='146-coming-kit-drop-preview';}
    if(body){body.dataset.rev145QaState='scent-decision-lens';body.dataset.tabaqRevision='146-coming-kit-drop-preview';}
  }
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init); else init();
  document.addEventListener('tabaq:page-change',function(){window.setTimeout(init,40);});
})();
/* REV145 — SCENT DECISION LENS END */


/* REV146 — COMING KIT DROP PREVIEW START
   Purpose: the uploaded concealed tray kit becomes an upcoming/future drop. It is watchable and previewable, not a standard cart product yet. */
(function(){
  'use strict';
  var root=document.documentElement;
  var body=document.body;
  var WATCH_KEY='tabaq_rev147_drop_queue_watchlist';
  var memoryWatch={};
  var DROP={
    id:'scent-layering-discovery-set',
    name:'Scent Layering Discovery Set',
    state:'upcoming',
    mode:'future-kit-drop',
    cartEnabled:false,
    imageClosed:'assets/tabaq_rev146_coming_kit_2.webp',
    imageOpen:'assets/tabaq_rev146_coming_kit_1.webp'
  };
  function qs(sel,ctx){return (ctx||document).querySelector(sel);}
  function qsa(sel,ctx){return Array.prototype.slice.call((ctx||document).querySelectorAll(sel));}
  function read(){try{return JSON.parse(localStorage.getItem(WATCH_KEY)||'{}')||{};}catch(e){return Object.assign({},memoryWatch);}}
  function write(data){memoryWatch=Object.assign({},data);try{localStorage.setItem(WATCH_KEY,JSON.stringify(data));}catch(e){} }
  function watching(){return !!read()[DROP.id];}
  function paintWatch(){
    var isWatching=watching();
    qsa('[data-rev146-watch-drop]').forEach(function(btn){
      var id=btn.getAttribute('data-rev146-watch-drop');
      if(id!==DROP.id)return;
      btn.classList.toggle('is-watching',isWatching);
      btn.setAttribute('aria-pressed',isWatching?'true':'false');
      btn.textContent=isWatching?'Watching this drop':'Watch this drop';
    });
    root.dataset.rev146WatchingDrop=isWatching?'true':'false';
  }
  function toggleWatch(){
    var data=read();
    if(data[DROP.id]) delete data[DROP.id];
    else data[DROP.id]={id:DROP.id,name:DROP.name,state:DROP.state,watchedAt:new Date().toISOString()};
    write(data);paintWatch();
  }
  function togglePreview(btn){
    var card=btn&&btn.closest&&btn.closest('[data-rev146-coming-drop]');
    if(!card)return;
    card.classList.toggle('is-kit-open');
    var open=card.classList.contains('is-kit-open');
    qsa('[data-rev146-preview-toggle]',card).forEach(function(control){control.textContent=open?'Close kit preview':'Open kit preview';control.setAttribute('aria-expanded',open?'true':'false');});
    root.dataset.rev146KitPreview=open?'open':'closed';
  }
  function registerDrop(){
    if(window.TABAQ_REV138_COMMERCE&&Array.isArray(window.TABAQ_REV138_COMMERCE.drops)){
      var exists=window.TABAQ_REV138_COMMERCE.drops.some(function(drop){return drop&&drop.id===DROP.id;});
      if(!exists) window.TABAQ_REV138_COMMERCE.drops.push({id:DROP.id,name:DROP.name,state:DROP.state,mode:DROP.mode,cartEnabled:false});
    }
    window.TABAQ_REV146_COMING_DROP=DROP;
  }
  function handleAction(event){
    var preview=event.target.closest&&event.target.closest('[data-rev146-preview-toggle]');
    if(preview){event.preventDefault();event.stopPropagation();togglePreview(preview);return;}
    var watch=event.target.closest&&event.target.closest('[data-rev146-watch-drop]');
    if(watch){event.preventDefault();event.stopPropagation();toggleWatch();return;}
  }
  function init(){
    registerDrop();
    qsa('[data-rev146-preview-toggle]').forEach(function(btn){
      if(btn.dataset.rev146Bound==='true')return;
      btn.dataset.rev146Bound='true';
      btn.setAttribute('aria-expanded','false');

    });
    qsa('[data-rev146-watch-drop]').forEach(function(btn){
      if(btn.dataset.rev146Bound==='true')return;
      btn.dataset.rev146Bound='true';
      btn.setAttribute('aria-pressed','false');

    });
    paintWatch();
    root.dataset.rev146QaState='coming-kit-drop-preview';
    root.dataset.rev146ComingDropId=DROP.id;
    root.dataset.rev146DropState=DROP.state;
    root.dataset.tabaqRevision='146-coming-kit-drop-preview';
    if(body){body.dataset.rev146QaState='coming-kit-drop-preview';body.dataset.tabaqRevision='146-coming-kit-drop-preview';}
  }
  document.addEventListener('click',handleAction,true);
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init,{once:true}); else init();
  document.addEventListener('tabaq:page-change',function(){window.setTimeout(init,80);});
})();
/* REV146 — COMING KIT DROP PREVIEW END */


/* REV147 — DROP QUEUE WATCHLIST STUDIO START
   Purpose: scalable future-drop queue + watch-interest storage. Does not add future drops to the standard PRODUCTS cart. */
(function(){
  'use strict';
  var root=document.documentElement;
  var body=document.body;
  var WATCH_KEY='tabaq_rev147_drop_queue_watchlist';
  var memoryWatch={};
  var DROPS=[
    {id:'scent-layering-discovery-set',name:'Scent Layering Discovery Set',state:'upcoming',mode:'future-kit-drop',cartEnabled:false,asset:'assets/tabaq_rev146_coming_kit_2.webp'},
    {id:'fresh-mist-teaser',name:'Fresh Mist Micro-Drop',state:'teaser',mode:'future-kit-drop',cartEnabled:false},
    {id:'archive-fire-sale-slot',name:'Archive Event Slot',state:'fire-sale-ready',mode:'future-fire-sale',cartEnabled:false},
    {id:'archived-proof-slot',name:'Past Drop Template',state:'archived',mode:'drop-history',cartEnabled:false}
  ];
  function qs(sel,ctx){return (ctx||document).querySelector(sel);}
  function qsa(sel,ctx){return Array.prototype.slice.call((ctx||document).querySelectorAll(sel));}
  function dropById(id){return DROPS.filter(function(drop){return drop.id===id;})[0]||null;}
  function read(){try{return JSON.parse(localStorage.getItem(WATCH_KEY)||'{}')||{};}catch(e){return Object.assign({},memoryWatch);}}
  function write(data){memoryWatch=Object.assign({},data);try{localStorage.setItem(WATCH_KEY,JSON.stringify(data));}catch(e){} paint();}
  function isWatched(id){return !!read()[id];}
  function watchedCount(){return Object.keys(read()).filter(function(id){return !!dropById(id);}).length;}
  function labelFor(btn,id,active){
    var isRev146=btn.hasAttribute('data-rev146-watch-drop');
    var state=(dropById(id)||{}).state||'';
    if(active) return isRev146?'Watching this drop':'Interest saved';
    if(isRev146) return 'Watch this drop';
    if(state==='teaser'||state==='fire-sale-ready'||state==='archived') return 'Save interest';
    return 'Watch drop';
  }
  function paint(){
    var data=read();
    qsa('[data-rev147-watch-drop], [data-rev146-watch-drop]').forEach(function(btn){
      var id=btn.getAttribute('data-rev147-watch-drop')||btn.getAttribute('data-rev146-watch-drop');
      var active=!!data[id];
      btn.classList.toggle('is-watching',active);
      btn.setAttribute('aria-pressed',active?'true':'false');
      btn.textContent=labelFor(btn,id,active);
    });
    qsa('[data-rev147-release-card]').forEach(function(card){
      var id=card.getAttribute('data-rev147-release-card');
      card.classList.toggle('is-watched',!!data[id]);
      card.dataset.rev147Watched=data[id]?'true':'false';
    });
    qsa('[data-rev147-watch-indicator]').forEach(function(el){
      var id=el.getAttribute('data-rev147-watch-indicator');
      var active=!!data[id];
      el.textContent=active?'Watched':'Not watched';
      var col=el.closest&&el.closest('.rev147-release-column');
      if(col) col.classList.toggle('is-watched',active);
    });
    qsa('[data-rev147-watch-count]').forEach(function(el){el.textContent=String(watchedCount());});
    root.dataset.rev147WatchedDrops=String(watchedCount());
  }
  function toggle(id){
    var drop=dropById(id); if(!drop) return;
    var data=read();
    if(data[id]) delete data[id];
    else data[id]={id:drop.id,name:drop.name,state:drop.state,mode:drop.mode,cartEnabled:false,watchedAt:new Date().toISOString()};
    write(data);
  }
  function openPreview(id){
    if(id!=='scent-layering-discovery-set')return;
    var card=qs('[data-rev146-coming-drop="scent-layering-discovery-set"]')||qs('[data-rev146-coming-drop="scent-layering-discovery-set-calendar"]');
    if(card){
      card.classList.add('is-kit-open');
      qsa('[data-rev146-preview-toggle]',card).forEach(function(control){control.textContent='Close kit preview';control.setAttribute('aria-expanded','true');});
      card.scrollIntoView({block:'center',behavior:'smooth'});
    }
    root.dataset.rev147PreviewDrop=id;
  }
  function registerDrops(){
    var commerce=window.TABAQ_REV138_COMMERCE;
    if(commerce&&Array.isArray(commerce.drops)){
      DROPS.forEach(function(drop){
        var exists=commerce.drops.some(function(existing){return existing&&existing.id===drop.id;});
        if(!exists){commerce.drops.push({id:drop.id,name:drop.name,state:drop.state,mode:drop.mode,cartEnabled:false});}
      });
    }
    window.TABAQ_REV147_DROP_QUEUE={drops:DROPS,readWatchlist:read,toggleWatch:toggle,paint:paint};
  }
  function handle(event){
    var rev147Btn=event.target.closest&&event.target.closest('[data-rev147-watch-drop]');
    if(rev147Btn){event.preventDefault();event.stopPropagation();toggle(rev147Btn.getAttribute('data-rev147-watch-drop'));return;}
    var preview=event.target.closest&&event.target.closest('[data-rev147-open-preview]');
    if(preview){event.preventDefault();event.stopPropagation();openPreview(preview.getAttribute('data-rev147-open-preview'));return;}
    var rev146Btn=event.target.closest&&event.target.closest('[data-rev146-watch-drop]');
    if(rev146Btn){window.setTimeout(paint,0);}
  }
  function init(){
    registerDrops();
    qsa('[data-rev147-watch-drop]').forEach(function(btn){btn.setAttribute('aria-pressed',isWatched(btn.getAttribute('data-rev147-watch-drop'))?'true':'false');});
    qsa('[data-rev147-release-card]').forEach(function(card){card.dataset.rev147CartEnabled='false';});
    paint();
    root.dataset.tabaqRevision='147-drop-queue-watchlist-studio';
    root.dataset.rev147QaState='drop-queue-watchlist-studio';
    root.dataset.rev147DropStates='teaser,upcoming,live,fire-sale-ready,archived';
    root.dataset.rev147FutureCartGuard='no-cart-until-launched';
    if(body){body.dataset.tabaqRevision='147-drop-queue-watchlist-studio';body.dataset.rev147QaState='drop-queue-watchlist-studio';}
  }
  document.addEventListener('click',handle,true);
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init,{once:true});else init();
  document.addEventListener('tabaq:page-change',function(){window.setTimeout(init,80);});
  window.addEventListener('storage',paint);
})();
/* REV147 — DROP QUEUE WATCHLIST STUDIO END */


/* REV148 — NEXT DROP GALLERY LIVE TIMER START
   Purpose: make the next-drop countdown live and make the uploaded donor kit native/tappable inside the existing page system. */
(function(){
  'use strict';
  var root=document.documentElement;
  var body=document.body;
  var timerId=null;
  var DEFAULT_TARGET='2026-06-01T09:00:00+02:00';
  function qsa(sel,ctx){return Array.prototype.slice.call((ctx||document).querySelectorAll(sel));}
  function two(n){n=Number(n)||0;return n<10?'0'+n:String(n);}
  function parts(ms){
    var total=Math.max(0,Math.floor(ms/1000));
    var days=Math.floor(total/86400); total-=days*86400;
    var hours=Math.floor(total/3600); total-=hours*3600;
    var minutes=Math.floor(total/60); var seconds=total-minutes*60;
    return {days:days,hours:hours,minutes:minutes,seconds:seconds};
  }
  function targetFor(el){
    var raw=el.getAttribute('data-rev148-countdown-target')||DEFAULT_TARGET;
    var date=new Date(raw);
    return isNaN(date.getTime())?new Date(DEFAULT_TARGET):date;
  }
  function setUnit(el,name,value){
    qsa('[data-rev148-time-unit="'+name+'"]',el).forEach(function(node){node.textContent=name==='days'?String(value):two(value);});
  }
  function paintTimer(el,now){
    var target=targetFor(el);
    var remaining=target.getTime()-now.getTime();
    var p=parts(remaining);
    setUnit(el,'days',p.days); setUnit(el,'hours',p.hours); setUnit(el,'minutes',p.minutes); setUnit(el,'seconds',p.seconds);
    var live=remaining<=0;
    el.dataset.rev148CountdownState=live?'live':'counting';
    var label=el.querySelector('.rev148-live-timer__label');
    if(label){label.textContent=live?(el.getAttribute('data-rev148-countdown-label')||'Drop')+' is live':(el.getAttribute('data-rev148-countdown-label')||'Drop opens')+' in';}
    el.setAttribute('aria-label',(label?label.textContent:'Drop countdown')+' '+p.days+' days '+p.hours+' hours '+p.minutes+' minutes '+p.seconds+' seconds');
    return live;
  }
  function tick(){
    var now=new Date();
    var all=qsa('[data-rev148-countdown]');
    var liveCount=0;
    all.forEach(function(el){if(paintTimer(el,now))liveCount++;});
    root.dataset.rev148LiveTimers=String(all.length);
    root.dataset.rev148NextDropState=liveCount?'live':'upcoming';
  }
  function setKitOpen(kit,open){
    if(!kit)return;
    kit.classList.toggle('is-open',!!open);
    kit.setAttribute('aria-expanded',open?'true':'false');
    var label=open?'Close animated kit tray':'Open animated kit tray';
    kit.setAttribute('aria-label',label);
  }
  function toggleKit(kit){setKitOpen(kit,!kit.classList.contains('is-open'));}
  function openAllKits(){qsa('[data-rev148-kit-toggle]').forEach(function(kit){setKitOpen(kit,true);});}
  function bind(){
    qsa('[data-rev148-kit-toggle]').forEach(function(kit){
      if(kit.dataset.rev148Bound==='true')return;
      kit.dataset.rev148Bound='true';
      kit.setAttribute('aria-expanded',kit.classList.contains('is-open')?'true':'false');
    });
  }
  function handle(event){
    var openAll=event.target.closest&&event.target.closest('[data-rev148-kit-open-all]');
    if(openAll){event.preventDefault();event.stopPropagation();openAllKits();openAll.textContent='Gallery kit open';return;}
    var kit=event.target.closest&&event.target.closest('[data-rev148-kit-toggle]');
    if(kit){event.preventDefault();event.stopPropagation();toggleKit(kit);}
  }
  function init(){
    bind();
    tick();
    if(timerId)window.clearInterval(timerId);
    timerId=window.setInterval(tick,1000);
    root.dataset.tabaqRevision='148-next-drop-gallery-live-timer';
    root.dataset.rev148QaState='next-drop-gallery-live-timer';
    root.dataset.rev148CountdownTarget=DEFAULT_TARGET;
    root.dataset.rev148FutureCartGuard='no-cart-until-live';
    if(body){body.dataset.tabaqRevision='148-next-drop-gallery-live-timer';body.dataset.rev148QaState='next-drop-gallery-live-timer';}
    window.TABAQ_REV148_NEXT_DROP={target:DEFAULT_TARGET,tick:tick,openAllKits:openAllKits};
  }
  document.addEventListener('click',handle,true);
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init,{once:true}); else init();
  document.addEventListener('tabaq:page-change',function(){window.setTimeout(init,80);});
})();
/* REV148 — NEXT DROP GALLERY LIVE TIMER END */


/* REV190 — REV167 SOURCE-TRUTH LAYERING HARD LOCK START
   Purpose: restore Rev167 as the source-truth Layering engine and keep the bottle-drop actor visible through the real route.
   Rule: one Layering route owner; no Rev187/Rev188/Rev189 actor patches; no second renderer; no iframe. */
(function(){
  var SCENES=[
    {id:'body',step:'01',name:'BODY MIST',micro:'spray cloud lands at the collarbone',empty:'assets/tabaq_asset_013.webp',final:'assets/tabaq_asset_014.webp',product:'assets/tabaq_asset_015.webp',fall:88,rot:-13,x:-5,startScale:1,accent:'#d9982d'},
    {id:'edp',step:'02',name:'EAU DE PARFUM',micro:'precise mist settles at the neck',empty:'assets/tabaq_asset_016.webp',final:'assets/tabaq_asset_017.webp',product:'assets/tabaq_asset_018.webp',fall:86,rot:11,x:4,startScale:1,accent:'#ec7b65'},
    {id:'oil',step:'03',name:'ACCENT OIL',micro:'rollerball lands on the pulse point',empty:'assets/tabaq_asset_019.webp',final:'assets/tabaq_asset_020.webp',product:'assets/tabaq_asset_021.webp',fall:72,rot:-8,x:0,startScale:1,accent:'#78a844'}
  ];
  function qs(s,c){return (c||document).querySelector(s);}
  function qsa(s,c){return Array.prototype.slice.call((c||document).querySelectorAll(s));}
  function clamp(v,min,max){return Math.max(min,Math.min(max,v));}
  function lerp(a,b,t){return a+(b-a)*t;}
  function smoother(t){return t*t*t*(t*(t*6-15)+10);}
  function easeOutBack(t){var c1=1.18,c3=c1+1;return 1+c3*Math.pow(t-1,3)+c1*Math.pow(t-1,2);}
  function seg(p,start,end){return clamp((p-start)/(end-start),0,1);}
  function setVars(el,vars){Object.keys(vars).forEach(function(k){el.style.setProperty(k,vars[k]);});}
  function currentPage(){return (document.body && document.body.dataset && document.body.dataset.page) || String(location.hash||'#home').replace(/^#/,'') || 'home';}
  function isLayering(){return currentPage()==='layering' || !!qs('.tabaq-page[data-page="layering"].is-active');}
  function root(){return qs('.tabaq-rev7drop[data-rev7-drop-animation]');}
  function mount(){return qs('#rev7drop-scenes');}
  function sceneMarkup(scene){
    return '<section class="rev7-scroll-scene" data-scene data-id="'+scene.id+'" data-fall="'+scene.fall+'" data-rot="'+scene.rot+'" data-x="'+scene.x+'" data-start-scale="'+scene.startScale+'" style="--accent:'+scene.accent+'">'+
      '<div class="rev7-scene-sticky"><div class="rev7-scene-grid">'+
        '<aside class="rev7-scene-copy" aria-label="'+scene.name+'"><span class="rev7-scene-step">Step '+scene.step+'</span><h2 class="rev7-scene-name">'+scene.name+'</h2><p class="rev7-scene-micro">'+scene.micro+'</p><div class="rev7-scene-lock">final layer locked</div></aside>'+
        '<figure class="rev7-artboard" aria-label="'+scene.name+' product drop">'+
          '<img class="rev7-layer-img rev7-model-empty" src="'+scene.empty+'" alt="" aria-hidden="true" />'+
          '<img class="rev7-layer-img rev7-product-drop" src="'+scene.product+'" alt="'+scene.name+' bottle falling into hand" />'+
          '<span class="rev7-landing-ring" aria-hidden="true"></span>'+
          '<img class="rev7-layer-img rev7-model-final" src="'+scene.final+'" alt="Final locked '+scene.name+' image with product held in hand" />'+
        '</figure>'+
        '<aside class="rev7-scene-side" aria-hidden="true"><span>'+scene.name+'</span> / scroll-to-settle</aside>'+
      '</div></div></section>';
  }
  function validateScene(scene,index){
    var expected=SCENES[index];
    if(!scene||!expected)return false;
    var product=qs('.rev7-product-drop',scene);
    var empty=qs('.rev7-model-empty',scene);
    var final=qs('.rev7-model-final',scene);
    return scene.getAttribute('data-id')===expected.id && product && product.getAttribute('src')===expected.product && empty && empty.getAttribute('src')===expected.empty && final && final.getAttribute('src')===expected.final;
  }
  function rebuildIfNeeded(){
    var m=mount();
    if(!m)return false;
    var scenes=qsa('.rev7-scroll-scene',m);
    var ok=scenes.length===SCENES.length && scenes.every(validateScene);
    if(!ok){
      m.innerHTML=SCENES.map(sceneMarkup).join('');
      scenes=qsa('.rev7-scroll-scene',m);
      scenes.forEach(function(scene){scene.dataset.rev190SourceTruth='true';});
      document.documentElement.dataset.rev190LayeringRebuilt='true';
    }else{
      scenes.forEach(function(scene){scene.dataset.rev190SourceTruth='true';});
    }
    return true;
  }
  function updateOne(scene){
    var rect=scene.getBoundingClientRect();
    var travel=Math.max(1,rect.height-window.innerHeight);
    var raw=clamp((0-rect.top)/travel,0,1);
    var state=scene.__rev190Lag || (scene.__rev190Lag={modelRaw:raw,lastRaw:raw});
    state.modelRaw += (raw-state.modelRaw)*.12;
    var modelRaw=clamp(state.modelRaw,0,1);
    var lagDelta=clamp(raw-modelRaw,-.18,.18);
    var fallStart=.06,fallEnd=.68,settleStart=.56,lockStart=.66,contactStart=.58,contactEnd=.84;
    var fallT=smoother(seg(raw,fallStart,fallEnd));
    var modelFallT=smoother(seg(modelRaw,fallStart,fallEnd));
    var settleT=easeOutBack(seg(raw,settleStart,.84));
    var contactT=smoother(seg(raw,contactStart,contactEnd));
    var finalT=smoother(seg(raw,lockStart,.90));
    var fallVh=Number(scene.dataset.fall||82);
    var rot=Number(scene.dataset.rot||0);
    var x=Number(scene.dataset.x||0);
    var startScale=Number(scene.dataset.startScale||1);
    var y=lerp(-fallVh,0,fallT);
    var wobble=Math.sin(fallT*Math.PI*2.45)*(1-fallT)*4.5;
    var settleDip=Math.sin(settleT*Math.PI)*5.5;
    var productOpacity=raw<.035?0:(raw>lockStart?1-(finalT*.92):1);
    var emptyOpacity=1-(finalT*.98);
    var lagY=clamp(-lagDelta*82,-22,22);
    var lagX=clamp(lagDelta*x*.34,-12,12);
    setVars(scene,{
      '--product-y':(y+settleDip)+'vh',
      '--product-x':(x*(1-fallT))+'px',
      '--product-rot':(lerp(rot,0,fallT)+wobble)+'deg',
      '--product-scale':String(lerp(startScale,1,fallT)),
      '--product-opacity':String(clamp(productOpacity,0,1)),
      '--rev88-contact':String(contactT),
      '--final-opacity':String(finalT),
      '--empty-opacity':String(emptyOpacity),
      '--rev86-lag-y':lagY+'px',
      '--rev86-lag-x':lagX+'px',
      '--rev86-lag-rot-y':clamp(lagDelta*14,-4.2,4.2)+'deg',
      '--rev86-lag-rot-x':clamp(-lagDelta*7,-2.4,2.4)+'deg',
      '--rev86-empty-scale':String(lerp(.995,1.012,modelFallT)),
      '--rev86-final-scale':String(lerp(.982,1.012,finalT)),
      '--rev86-final-z':lerp(18,42,finalT)+'px',
      '--ring-opacity':String(Math.sin(seg(raw,.76,.96)*Math.PI)*.44),
      '--ring-scale':String(lerp(.35,1.18,seg(raw,.76,.96))),
      '--drop-shadow':String(lerp(.04,.22,fallT)),
      '--ground-shadow':String(lerp(.05,.22,finalT)),
      '--shadow-scale':String(lerp(.7,1.08,finalT)),
      '--glow-scale':String(lerp(.72,1.05,fallT)),
      '--stage-lift':lerp(14,-4,fallT)+'px'
    });
    scene.dataset.rev190Raw=raw.toFixed(3);
    return raw;
  }
  var tickQueued=false;
  function updateAll(){
    tickQueued=false;
    var r=root();
    var m=mount();
    if(!r||!m)return;
    document.documentElement.classList.toggle('rev190-layering-source-truth',isLayering());
    if(document.body)document.body.classList.toggle('rev190-layering-source-truth',isLayering());
    rebuildIfNeeded();
    var scenes=qsa('.rev7-scroll-scene',m);
    var progress=0;
    scenes.forEach(function(scene,index){
      var p=updateOne(scene);
      if(p>0&&p<1)progress=(index+p)/Math.max(scenes.length,1);
      if(p>=1)progress=Math.max(progress,(index+1)/Math.max(scenes.length,1));
    });
    var bar=qs('[data-progress]',r);
    if(bar)bar.style.transform='scaleX('+clamp(progress,0,1)+')';
    document.documentElement.dataset.rev190LayeringScenes=String(scenes.length);
    document.documentElement.dataset.rev190LayeringState='rev167-source-truth-active';
  }
  function requestUpdate(){
    if(!tickQueued){tickQueued=true;requestAnimationFrame(updateAll);}
  }
  function boot(){
    rebuildIfNeeded();
    updateAll();
    ['scroll','resize','orientationchange','hashchange','load'].forEach(function(type){window.addEventListener(type,requestUpdate,{passive:true});});
    window.addEventListener('tabaq:page-change',function(){window.setTimeout(function(){rebuildIfNeeded();requestUpdate();},40);});
    if(document.fonts&&document.fonts.ready){document.fonts.ready.then(requestUpdate).catch(function(){});}
    document.documentElement.dataset.tabaqRevision='190-rev167-source-truth-layering-restored';
  }
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',boot,{once:true});else boot();
})();
/* REV190 — REV167 SOURCE-TRUTH LAYERING HARD LOCK END */


/* REV194 — BUYER CLARITY ROUTE STATE SEAL START
   Purpose: keep the document revision truthful after older revision modules write stale metadata. */
