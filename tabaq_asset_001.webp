      const active = saved.has(btn.getAttribute('data-rev43-add'));
      btn.classList.toggle('is-added', active);
      btn.textContent = active ? 'On early line' : (btn.dataset.rev51Label || btn.dataset.rev48Label || 'Join the early line');
    });
  }
  function meter(label, value, accent){
    return `<div class="rev43-meter"><span>${label}</span><div class="rev43-meter-track"><div class="rev43-meter-fill" style="--v:${value};--accent:${accent}"></div></div><em>${value}</em></div>`;
  }
  function openProfile(id){
    const kit = KITS[id]; if(!kit) return;
    const dialog = $('#rev43KitProfileDialog'); if(!dialog) return;
    const shell = $('#rev43KitProfileShell');
    const hero = $('#rev43DialogHero');
    shell.style.setProperty('--profile-a', kit.tile);
    shell.style.setProperty('--profile-bg', kit.tile);
    hero.style.setProperty('--profile-bg', kit.tile);
    hero.setAttribute('data-num', kit.num);
    $('#rev43DialogKicker').textContent = `${kit.short} / ${kit.price}`;
    $('#rev43DialogTitle').textContent = kit.name;
    $('#rev43DialogSummary').textContent = kit.summary;
    $('#rev43DialogPrice').textContent = kit.price;
    $('#rev43DialogNotes').innerHTML = kit.notes.map(n => `<span class="rev43-note-chip">${n}</span>`).join('');
    $('#rev43DialogPyramid').innerHTML = Object.entries(kit.pyramid).map(([k,v]) => `<div><b>${k}</b><span>${v}</span></div>`).join('');
    $('#rev43DialogBars').innerHTML = Object.entries(kit.metrics).map(([k,v]) => meter(k,v,kit.accent)).join('');
    $('#rev43DialogLayers').innerHTML = kit.layers.map(l => `<div><b>${l[0]}</b><span>${l[1]}</span><span>${l[2]}</span></div>`).join('');
    const choose = $('#rev43DialogChoose');
    choose.onclick = () => { closeProfile(); location.hash = kit.page; };
    if(typeof dialog.showModal === 'function') dialog.showModal(); else dialog.setAttribute('open','');
  }
  function closeProfile(){ const d = $('#rev43KitProfileDialog'); if(d) d.close ? d.close() : d.removeAttribute('open'); }
  function initFilters(){
    const buttons = $$('.tabaq-page[data-page="shop"] [data-rev43-filter]');
    const cards = $$('.tabaq-page[data-page="shop"] .product-card.rev43-commerce-card');
    buttons.forEach(btn => btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-rev43-filter') || 'all';
      buttons.forEach(b => { b.classList.toggle('is-active', b === btn); b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'); });
      cards.forEach(card => {
        const tags = (card.getAttribute('data-kit-tags') || '').split(/\s+/);
        const show = filter === 'all' || tags.includes(filter);
        card.classList.toggle('is-filter-hidden', !show);
      });
    }));
  }
  function bind(){
    document.addEventListener('click', (e) => {
      const profileBtn = e.target.closest('[data-rev43-profile]');
      if(profileBtn){ e.preventDefault(); e.stopPropagation(); openProfile(profileBtn.getAttribute('data-rev43-profile')); return; }
      const addBtn = e.target.closest('[data-rev43-add]');
      if(addBtn){ e.preventDefault(); saveKit(addBtn.getAttribute('data-rev43-add')); return; }
      if(e.target.closest('[data-rev43-close]')){ e.preventDefault(); closeProfile(); }
    });
    const dialog = $('#rev43KitProfileDialog');
    if(dialog) dialog.addEventListener('click', e => { if(e.target === dialog) closeProfile(); });
    initFilters();
    updateDropButtons();
  }
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bind); else bind();
  window.addEventListener('hashchange', updateDropButtons);
})();
/* REV43 — KIT COMMERCE / SCENT PROFILE ENHANCEMENT END */
/* REV78 — INLINE SCRIPT BLOCK 5 END */


/* REV78 — INLINE SCRIPT BLOCK 6 START */
/* REV CLEANUP — PRODUCT DETAIL KIT PREVIEW MOUNT START
   Purpose: keep product-detail kit previews, remove automatic open/close pulses. */
(function(){
  const DETAIL_PAGE_TO_KIT = {
    'product-clean-skin':'clean-skin',
    'product-soft-bloom':'soft-bloom',
    'product-amber-haze':'amber-haze',
    'product-juice-drift':'juice-drift'
  };

  function currentPage(){
    return (document.body && document.body.dataset.page) || String(location.hash || '#home').replace(/^#/, '') || 'home';
  }

  function bindPack(pack){
    if(!pack || pack.dataset.rev44Bound === 'true') return;
    pack.dataset.rev44Bound = 'true';
    pack.addEventListener('click', function(event){
      event.stopPropagation();
      pack.classList.toggle('is-open');
    });
    pack.addEventListener('keydown', function(event){
      if(event.key === 'Enter' || event.key === ' '){
        event.preventDefault();
        pack.classList.toggle('is-open');
      }
    });
  }

  function mountDetailKits(){
    document.querySelectorAll('[data-detail-kit-mount]').forEach(function(stage){
      if(stage.dataset.rev44Mounted === 'true') return;
      const kitId = stage.getAttribute('data-detail-kit-mount');
      const source = document.querySelector('.product-card.has-kit-motion[data-kit-id="' + kitId + '"] .rev29-kit-preview');
      const target = stage.querySelector('.rev44-kit-mount');
      if(!source || !target) return;
      const clone = source.cloneNode(true);
      clone.classList.add('rev44-detail-kit-preview');
      const originalMotion = clone.getAttribute('data-motion') || 'animated kit';
      clone.setAttribute('data-motion', originalMotion + ' · large preview');
      clone.querySelectorAll('[id]').forEach(function(node){ node.removeAttribute('id'); });
      const pack = clone.querySelector('[data-kit-toggle]');
      if(pack){
        pack.classList.remove('is-open');
        pack.setAttribute('aria-label', 'Open large animated ' + kitId.replace(/-/g, ' ') + ' kit preview');
        bindPack(pack);
      }
      target.replaceChildren(clone);
      stage.dataset.rev44Mounted = 'true';
    });
  }

  function markActiveDetailPage(){
    mountDetailKits();
    const page = currentPage();
    const kitId = DETAIL_PAGE_TO_KIT[page];
    document.querySelectorAll('.rev43-detail-page').forEach(function(pageNode){
      pageNode.classList.remove('rev44-detail-page-active');
    });
    if(!kitId) return;
    const section = document.querySelector('.tabaq-page[data-page="' + page + '"]');
    if(!section) return;
    const pageNode = section.querySelector('.rev43-detail-page');
    if(pageNode) pageNode.classList.add('rev44-detail-page-active');
  }

  window.addEventListener('load', markActiveDetailPage);
  window.addEventListener('resize', function(){ window.requestAnimationFrame(mountDetailKits); });
  window.addEventListener('hashchange', function(){ window.setTimeout(markActiveDetailPage, 140); });
  window.addEventListener('tabaq:page-change', function(){ window.setTimeout(markActiveDetailPage, 140); });
})();
/* REV CLEANUP — PRODUCT DETAIL KIT PREVIEW MOUNT END */
/* REV78 — INLINE SCRIPT BLOCK 6 END */


/* REV78 — INLINE SCRIPT BLOCK 7 START */
/* REV49 — DROP LIST CONVERSION SYSTEM START
   One purpose: intercept Join the early line CTAs and convert them into a real kit-specific drop access panel. */
(function(){
  const KITS = {
    'clean-skin': {
      id:'clean-skin', num:'01', name:'Clean Skin', price:'R890', color:'#d9f5e8', motion:'wood',
      hook:'Fresh, soft, close. Your daily clean fragrance kit.',
      included:[['01','Body Mist','50ml mineral lift'],['02','Eau de Parfum','30ml clean skin accord'],['03','Oil 01','5ml soft cotton warmth'],['04','Oil 02','5ml quiet musk finish']]
    },
    'soft-bloom': {
      id:'soft-bloom', num:'02', name:'Soft Bloom', price:'R890', color:'#ffe0ed', motion:'concealed',
      hook:'Petal-soft and pretty. The easy giftable floral.',
      included:[['01','Body Mist','50ml pink petal lift'],['02','Eau de Parfum','30ml floral heart'],['03','Oil 01','5ml powder-soft skin'],['04','Oil 02','5ml creamy finish']]
    },
    'amber-haze': {
      id:'amber-haze', num:'03', name:'Amber Haze', price:'R950', color:'#ffd9a6', motion:'brown',
      hook:'Warm, smooth, evening-ready. A richer scent trail.',
      included:[['01','Body Mist','50ml golden warmth'],['02','Eau de Parfum','30ml amber signature'],['03','Oil 01','5ml resin-soft skin'],['04','Oil 02','5ml smoky second finish']]
    },
    'juice-drift': {
      id:'juice-drift', num:'04', name:'Juice Drift', price:'R890', color:'#ffec6d', motion:'transparent',
      hook:'Bright, juicy, social. The playful weekend kit.',
      included:[['01','Body Mist','50ml citrus splash'],['02','Eau de Parfum','30ml juicy identity'],['03','Oil 01','5ml soft fruit skin'],['04','Oil 02','5ml clean sweet finish']]
    }
  };
  const STORAGE_KEY = 'tabaq_rev43_drop_list';
  const CONTACT_KEY = 'tabaq_rev49_drop_contacts';
  let currentKitId = 'clean-skin';

  const $ = (sel, root=document) => root.querySelector(sel);
  const $$ = (sel, root=document) => Array.from(root.querySelectorAll(sel));
  const panel = $('#rev49DropPanel');
  if(!panel) return;

  function getSaved(){ try{return JSON.parse(localStorage.getItem(STORAGE_KEY)||'[]')}catch(e){return []} }
  function setSaved(id){
    const saved = new Set(getSaved());
    saved.add(id);
    try{localStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(saved)))}catch(e){}
    updateDropButtons();
  }
  function updateDropButtons(){
    const saved = new Set(getSaved());
    $$('[data-rev43-add]').forEach(btn => {
      const id = btn.getAttribute('data-rev43-add');
      const active = saved.has(id);
      btn.classList.toggle('is-added', active);
      btn.textContent = active ? 'On early line' : (btn.dataset.rev51Label || btn.dataset.rev48Label || 'Join the early line');
    });
  }
  function saveContact(id){
    const email = ($('#rev49DropEmail') || {}).value || '';
    const whatsapp = ($('#rev49DropWhatsapp') || {}).value || '';
    let contacts = [];
    try{contacts = JSON.parse(localStorage.getItem(CONTACT_KEY)||'[]')}catch(e){contacts=[]}
    contacts = contacts.filter(item => item && item.id !== id);
    contacts.push({id, email:email.trim(), whatsapp:whatsapp.trim(), savedAt:new Date().toISOString()});
    try{localStorage.setItem(CONTACT_KEY, JSON.stringify(contacts))}catch(e){}
  }
  function cloneKitPreview(kit){
    const mount = $('#rev49DropKitMount');
    if(!mount) return;
    mount.innerHTML = '';
    const source = document.querySelector(`.product-card[data-kit-id="${kit.id}"] .rev29-kit-preview`) || document.querySelector(`.rev43-commerce-card[data-kit-id="${kit.id}"] .rev29-kit-preview`);
    if(source){
      const clone = source.cloneNode(true);
      clone.querySelectorAll('[id]').forEach(el => el.removeAttribute('id'));
      clone.querySelectorAll('button').forEach(btn => {
        btn.type = 'button';
        btn.setAttribute('tabindex','-1');
        btn.classList.add('is-open');
        btn.addEventListener('click', () => btn.classList.toggle('is-open'));
      });
      mount.appendChild(clone);
      window.setTimeout(() => clone.querySelectorAll('.rev29-pack').forEach(pack => pack.classList.add('is-open')), 90);
    } else {
      mount.innerHTML = '<div style="font-weight:950;letter-spacing:-.04em;font-size:48px;line-height:.9">TABAQ<br/>KIT</div>';
    }
  }
  function populatePanel(id){
    const kit = KITS[id] || KITS['clean-skin'];
    currentKitId = kit.id;
    panel.classList.remove('is-confirmed');
    panel.style.setProperty('--rev49-kit-color', kit.color);
    const visual = $('#rev49DropVisual');
    if(visual){ visual.dataset.num = kit.num; visual.style.setProperty('--rev49-kit-color', kit.color); }
    const shell = $('#rev49DropShell');
    if(shell) shell.style.setProperty('--rev49-kit-color', kit.color);
    const kicker = $('#rev49DropKicker');
    const title = $('#rev49DropTitle');
    const summary = $('#rev49DropSummary');
    const price = $('#rev49DropPrice');
    const status = $('#rev49DropStatus');
    const submit = $('#rev49DropSubmit');
    const included = $('#rev49DropIncluded');
    if(kicker) kicker.textContent = `Join early access / ${kit.num}`;
    if(title) title.textContent = kit.name;
    if(summary) summary.textContent = kit.hook;
    if(price) price.textContent = kit.price;
    if(status) status.textContent = 'First access · complete kits first';
    if(submit) submit.textContent = `Join the early line — ${kit.price}`;
    if(included){
      included.innerHTML = kit.included.map(item => `<span><em>${item[0]}</em><strong>${item[1]}</strong>${item[2]}</span>`).join('');
    }
    cloneKitPreview(kit);
  }
  function openPanel(id){
    populatePanel(id);
    if(typeof panel.showModal === 'function') panel.showModal(); else panel.setAttribute('open','');
    window.setTimeout(() => {
      const first = $('#rev49DropEmail') || $('[data-rev49-close]');
      if(first && first.focus) first.focus({preventScroll:true});
    }, 80);
  }
  function closePanel(){
    if(typeof panel.close === 'function') panel.close(); else panel.removeAttribute('open');
  }

  /* Capture phase deliberately prevents the older Rev43 add handler from swallowing the conversion moment. */
  document.addEventListener('click', function(event){
    const addBtn = event.target && event.target.closest && event.target.closest('[data-rev43-add]');
    if(!addBtn) return;
    event.preventDefault();
    event.stopImmediatePropagation();
    const id = addBtn.getAttribute('data-rev43-add') || 'clean-skin';
    openPanel(id);
  }, true);

  panel.addEventListener('click', function(event){
    if(event.target === panel || event.target.closest('[data-rev49-close]')){ event.preventDefault(); closePanel(); }
    const viewDrops = event.target.closest('[data-rev49-view-drops]');
    if(viewDrops){
      event.preventDefault();
      closePanel();
      location.hash = 'drop';
      window.dispatchEvent(new CustomEvent('tabaq:page-change', {detail:{page:'drop', source:'rev49-drop-panel'}}));
    }
  });
  const form = $('#rev49DropForm');
  if(form){
    form.addEventListener('submit', function(event){
      event.preventDefault();
      setSaved(currentKitId);
      saveContact(currentKitId);
      const kit = KITS[currentKitId] || KITS['clean-skin'];
      const copy = $('#rev49DropSuccessCopy');
      if(copy) copy.textContent = `${kit.name} is saved. You are on the early access line for the ${kit.price} complete fragrance kit.`;
      panel.classList.add('is-confirmed');
    });
  }
  window.addEventListener('keydown', function(event){ if(event.key === 'Escape' && panel.hasAttribute('open')) closePanel(); });
  window.addEventListener('hashchange', updateDropButtons);
  window.addEventListener('storage', updateDropButtons);
  updateDropButtons();
  window.TABAQ_REV49_DROP_LIST = { open:openPanel, kits:KITS };
})();
/* REV49 — DROP LIST CONVERSION SYSTEM END */
/* REV78 — INLINE SCRIPT BLOCK 7 END */


/* REV78 — INLINE SCRIPT BLOCK 8 START */
/* REV50 — DROP PAGE EVENT ARCHITECTURE HELPER START
   Purpose: generic drop CTAs guide users to kit choice instead of silently choosing a default kit. */
(function(){
  document.addEventListener('click', function(event){
    const trigger = event.target && event.target.closest && event.target.closest('[data-rev50-scroll-kits]');
    if(!trigger) return;
    event.preventDefault();
    const target = document.getElementById('rev50-drop-kits') || document.querySelector('.rev50-drop-kits');
    if(target && target.scrollIntoView) target.scrollIntoView({behavior:'smooth', block:'start'});
  });
})();
/* REV50 — DROP PAGE EVENT ARCHITECTURE HELPER END */
/* REV78 — INLINE SCRIPT BLOCK 8 END */


/* REV78 — INLINE SCRIPT BLOCK 9 START */
/* REV51 — COMMERCE CLARITY LOCK HELPER START
   Purpose: enforce consistent drop-list language after older saved-state scripts update button copy. */
(function(){
  const PRICE = {'clean-skin':'R890','soft-bloom':'R890','amber-haze':'R950','juice-drift':'R890'};
  function normalizeDropLabels(){
    document.querySelectorAll('[data-rev43-add]').forEach(function(btn){
      const id = btn.getAttribute('data-rev43-add');
      const price = PRICE[id] || 'R890';
      const label = 'Join the early line — ' + price;
      btn.dataset.rev48Label = label;
      btn.dataset.rev51Label = label;
      if(!btn.classList.contains('is-added')) btn.textContent = label;
    });
  }
  document.addEventListener('DOMContentLoaded', normalizeDropLabels);
  window.addEventListener('hashchange', function(){ window.requestAnimationFrame(normalizeDropLabels); });
  window.addEventListener('storage', function(){ window.requestAnimationFrame(normalizeDropLabels); });
  window.TABAQ_REV51_COMMERCE_CLARITY = { normalizeDropLabels: normalizeDropLabels };
})();
/* REV51 — COMMERCE CLARITY LOCK HELPER END */
/* REV78 — INLINE SCRIPT BLOCK 9 END */


/* REV78 — INLINE SCRIPT BLOCK 10 START */
/* REV40 — AWWWARDS DISCIPLINE + SHOP EDITORIAL MOTION POLISH START
   Purpose: award-level discipline without veering off: robust ribbon, larger hero product presence,
   slower reversible docking, no duplicated Body Mist, and stable Layering reinitialisation. */
(function(){
  'use strict';
  var ROLES = ['mist','edp','oil1','oil2'];
  var BASE_ROTATION = {mist:-5,edp:2,oil1:-4,oil2:5};
  var DOCK_ROTATION = {mist:0,edp:0,oil1:0,oil2:0};
  var CURVE_DESKTOP = 230;
  var CURVE_MOBILE = 88;
  var RESIZE_WAIT = 120;
  var FLIGHT_START = .018;
  var FLIGHT_END = .988;
  var SOURCE_FADE_END = .30;
  var TARGET_REVEAL_START = .74;
  var TARGET_REVEAL_END = .91;
  var CLONE_IN_END = .09;
  var CLONE_OUT_START = .90;
  var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var state = {measured:false,items:[],startY:0,endY:1,raf:0,resizeTimer:0,layer:null,lastPage:''};

  function qs(sel,root){ return (root||document).querySelector(sel); }
  function qsa(sel,root){ return Array.prototype.slice.call((root||document).querySelectorAll(sel)); }
  function clamp(n,a,b){ return Math.max(a,Math.min(b,n)); }
  function lerp(a,b,t){ return a + (b-a) * t; }
  function smoothstep(a,b,x){ var t=clamp((x-a)/(b-a),0,1); return t*t*(3-2*t); }
  function smoother(t){ return t*t*t*(t*(t*6-15)+10); }
  function px(n){ return Math.round(n * 1000) / 1000; }
  function currentPageName(){ return (window.location.hash || '#home').replace('#','') || 'home'; }
  function isShopActive(){ return currentPageName() === 'shop'; }
  function shopPage(){ return qs('.tabaq-page[data-page="shop"]'); }
  function docRect(el){ var r = el.getBoundingClientRect(); return {left:r.left + window.scrollX, top:r.top + window.scrollY, width:r.width, height:r.height, right:r.right + window.scrollX, bottom:r.bottom + window.scrollY}; }
  function bottomCentre(r){ return {x:r.left + r.width/2, y:r.top + r.height}; }

  function repairRibbon(){
    var ribbon = qs('.drop-time-ribbon');
    var track = ribbon && qs('.drop-time-ribbon__track', ribbon);
    if(!ribbon || !track) return;
    var labels = ['Drop date shared before launch','Early access opens first','Complete kits launch first','Prices shown before checkout'];
    var spans = qsa('span', track).filter(function(s){ return s.textContent.trim(); });
    if(spans.length < 8){
      track.innerHTML = '';
      labels.concat(labels, labels).forEach(function(label){
        var span = document.createElement('span');
        span.textContent = label;
        track.appendChild(span);
      });
    }
  }

  function ensureLayer(){
    if(state.layer && document.body.contains(state.layer)) return state.layer;
    var old = qs('.rev39-shop-dock-layer');
    if(old) old.remove();
    var layer = document.createElement('div');
    layer.className = 'rev40-shop-dock-layer';
    layer.setAttribute('aria-hidden','true');
    document.body.appendChild(layer);
    state.layer = layer;
    return layer;
  }
  function ensureClone(role, sourceImg){
    var layer = ensureLayer();
    var clone = qs('.rev40-shop-dock-bottle[data-rev40-role="' + role + '"]', layer);
    if(!clone){
      clone = document.createElement('figure');
      clone.className = 'rev40-shop-dock-bottle';
      clone.dataset.rev40Role = role;
      var img = document.createElement('img');
      img.alt = '';
      img.decoding = 'async';
      clone.appendChild(img);
      layer.appendChild(clone);
    }
    var imgEl = qs('img', clone);
    if(imgEl && sourceImg && imgEl.src !== sourceImg.src) imgEl.src = sourceImg.src;
    return clone;
  }
  function hideLayer(){
    if(!state.layer) return;
    qsa('.rev40-shop-dock-bottle', state.layer).forEach(function(el){
      el.classList.remove('is-visible');
      el.style.opacity = '0';
      el.style.visibility = 'hidden';
    });
  }
  function clearShopMotion(page){
    if(!page) return;
    page.classList.remove('rev40-dock-flight','rev40-docked','rev39-dock-flight','rev39-docked','rev38-dock-flight','rev38-docked');
    qsa('.shop-motion-bottle', page).forEach(function(el){ el.style.opacity = ''; el.style.visibility = ''; el.style.filter = ''; });
    qsa('.rev52-role-product img', page).forEach(function(el){ el.style.opacity = ''; el.style.visibility = ''; el.style.filter = ''; });
    qsa('.rev40-dock-cue,.rev39-dock-cue,.rev38-dock-cue', page).forEach(function(el){ el.classList.remove('rev40-dock-cue','rev39-dock-cue','rev38-dock-cue'); });
    hideLayer();
  }
  function setWaiting(page){
    if(!page || reduced) return;
    page.classList.remove('rev40-dock-flight','rev40-docked','rev39-dock-flight','rev39-docked');
    qsa('.shop-motion-bottle', page).forEach(function(el){ el.style.opacity = '1'; el.style.visibility = 'visible'; });
    qsa('.rev52-role-product img', page).forEach(function(el){ el.style.opacity = '0'; el.style.visibility = 'hidden'; });
    hideLayer();
  }
  function setFallback(page){
    if(!page) return;
    page.classList.remove('rev40-dock-flight','rev40-docked','rev39-dock-flight','rev39-docked');
    qsa('.shop-motion-bottle', page).forEach(function(el){ el.style.opacity = '1'; el.style.visibility = 'visible'; });
    qsa('.rev52-role-product img', page).forEach(function(el){ el.style.opacity = '1'; el.style.visibility = 'visible'; });
    hideLayer();
  }
  function setDocked(page){
    if(!page || reduced) return;
    page.classList.remove('rev40-dock-flight','rev39-dock-flight','rev38-dock-flight');
    page.classList.add('rev40-docked');
    qsa('.shop-motion-bottle', page).forEach(function(el){ el.style.opacity = '0'; el.style.visibility = 'hidden'; });
    qsa('.rev52-role-product img', page).forEach(function(el){ el.style.opacity = '1'; el.style.visibility = 'visible'; });
    hideLayer();
  }

  function runPageReveal(pageName){
    var name = pageName || currentPageName();
    if(state.lastPage === name) return;
    state.lastPage = name;
    qsa('.tabaq-page').forEach(function(page){ page.classList.remove('rev35-page-entering','rev38-page-entering','rev39-page-entering','rev40-page-entering'); });
    var active = qs('.tabaq-page[data-page="' + name + '"]') || qs('.tabaq-page[data-page="home"]');
    if(!active || reduced) return;
    active.classList.add('rev40-page-entering');
    window.setTimeout(function(){ active.classList.remove('rev40-page-entering'); }, 760);
  }

  function measureShop(){
    var page = shopPage();
    if(!page || reduced) return false;
    if(!isShopActive()){
      clearShopMotion(page);
      state.measured = false;
      return false;
    }
    var hero = qs('.page-hero', page);
    var guide = qs('.rev48-shop-guide', page);
    if(!hero || !guide) return false;

    var items = [];
    for(var i=0;i<ROLES.length;i++){
      var role = ROLES[i];
      var sourceFigure = qs('.shop-motion-bottle[data-shop-role="' + role + '"]', page);
      var sourceImg = sourceFigure && qs('img', sourceFigure);
      var targetCard = qs('.rev52-role-card[data-role-product="' + role + '"]', page);
      var targetImg = targetCard && qs('.rev52-role-product img', targetCard);
      if(!sourceFigure || !sourceImg || !targetCard || !targetImg) return false;

      sourceFigure.style.visibility = 'visible';
      targetImg.style.visibility = 'visible';
      targetImg.style.opacity = '1';

      var sourceRect = docRect(sourceImg);
      var targetRect = docRect(targetImg);
      if(sourceRect.width < 5 || sourceRect.height < 5 || targetRect.width < 5 || targetRect.height < 5) return false;

      var clone = ensureClone(role, sourceImg);
      clone.style.width = px(sourceRect.width) + 'px';
      clone.style.height = px(sourceRect.height) + 'px';

      items.push({
        role:role, i:i, sourceFigure:sourceFigure, sourceImg:sourceImg,
        targetCard:targetCard, targetImg:targetImg, clone:clone,
        source:bottomCentre(sourceRect), target:bottomCentre(targetRect),
        sourceW:sourceRect.width, sourceH:sourceRect.height,
        targetW:targetRect.width, targetH:targetRect.height,
        scale:clamp(targetRect.height / sourceRect.height, .36, 1.04),
        rot0:BASE_ROTATION[role] || 0, rot1:DOCK_ROTATION[role] || 0
      });
    }

    var heroTop = docRect(hero).top;
    var guideTop = docRect(guide).top;
    var vh = Math.max(window.innerHeight, 1);
    /* Long editorial runway. Dock is complete before the role cards become the reading target. */
    var end = Math.max(heroTop + vh * 1.12, guideTop - vh * .70);
    var minTravel = Math.max(1160, vh * 1.34);
    var preferredStart = Math.max(0, heroTop + vh * .14);
    var start = Math.max(0, end - minTravel);
    if(end - preferredStart >= vh * 1.02) start = preferredStart;

    state.startY = start;
    state.endY = Math.max(start + minTravel, end);
    state.items = items;
    state.measured = true;
    return true;
  }
  function rawDockProgress(){ return clamp((window.scrollY - state.startY) / Math.max(1, state.endY - state.startY), 0, 1); }

  function draw(progress){
    var page = shopPage();
    if(!page || !isShopActive() || !state.measured){ hideLayer(); return; }
    var visual = clamp(progress,0,1);
    if(visual <= FLIGHT_START){ setWaiting(page); return; }
    if(visual >= FLIGHT_END){ setDocked(page); return; }

    page.classList.add('rev40-dock-flight');
    page.classList.remove('rev40-docked','rev39-docked','rev38-docked');

    var sourceOpacity = 1 - smoothstep(FLIGHT_START, SOURCE_FADE_END, visual);
    var targetOpacity = smoothstep(TARGET_REVEAL_START, TARGET_REVEAL_END, visual);
    var cloneOpacity = smoothstep(FLIGHT_START, CLONE_IN_END, visual) * (1 - smoothstep(CLONE_OUT_START, FLIGHT_END, visual));
    var curveLift = window.innerWidth < 760 ? CURVE_MOBILE : CURVE_DESKTOP;

    state.items.forEach(function(item){
      var p = smoother(smoothstep(.025,.975,visual));
      var stagger = (item.i - 1.5) * 12 * Math.sin(p * Math.PI);
      var x = lerp(item.source.x, item.target.x, p) + stagger;
      var y = lerp(item.source.y, item.target.y, p) - Math.sin(p * Math.PI) * curveLift;
      var scale = lerp(1, item.scale, p);
      var rot = lerp(item.rot0, item.rot1, p);
      var viewportX = x - window.scrollX;
      var viewportY = y - window.scrollY;
      var clone = item.clone;

      item.sourceFigure.style.opacity = px(sourceOpacity);
      item.sourceFigure.style.visibility = sourceOpacity > .02 ? 'visible' : 'hidden';
      item.targetImg.style.opacity = px(targetOpacity);
      item.targetImg.style.visibility = targetOpacity > .02 ? 'visible' : 'hidden';
      item.targetCard.classList.toggle('rev40-dock-cue', visual > .78 && visual < .99);

      clone.style.width = px(item.sourceW) + 'px';
      clone.style.height = px(item.sourceH) + 'px';
      clone.style.transform = 'translate3d(' + px(viewportX - item.sourceW/2) + 'px,' + px(viewportY - item.sourceH) + 'px,0) scale(' + px(scale) + ') rotate(' + px(rot) + 'deg)';
      clone.style.opacity = px(cloneOpacity);
      clone.style.visibility = cloneOpacity > .012 ? 'visible' : 'hidden';
      clone.classList.toggle('is-visible', cloneOpacity > .012);
    });
  }

  function render(){
    state.raf = 0;
    var page = shopPage();
    if(!page || reduced){ hideLayer(); return; }
    if(!isShopActive()){
      clearShopMotion(page);
      return;
    }
    if(!state.measured && !measureShop()){
      setFallback(page);
      return;
    }
    draw(rawDockProgress());
  }
  function requestRender(){ if(state.raf) return; state.raf = window.requestAnimationFrame(render); }
  function refreshSoon(){
    window.clearTimeout(state.resizeTimer);
    state.resizeTimer = window.setTimeout(function(){ state.measured = false; measureShop(); requestRender(); }, RESIZE_WAIT);
  }
  function onRouteChange(pageName){
    repairRibbon();
    runPageReveal(pageName);
    state.measured = false;
    window.setTimeout(function(){ measureShop(); requestRender(); }, 80);
  }

  function ensureLayeringScenes(){
    var root = document.querySelector('.tabaq-rev7drop[data-rev7-drop-animation]');
    var mount = document.querySelector('#rev7drop-scenes');
    if(!root || !mount) return;
    if(mount.children.length === 0 && typeof window.TABAQRev7LayeringInit === 'function'){
      delete root.dataset.rev7DropReady;
      window.TABAQRev7LayeringInit();
    }
  }
  function onLayeringRoute(pageName){
    var name = pageName || currentPageName();
    if(name === 'layering') window.setTimeout(ensureLayeringScenes, 80);
  }

  function boot(){
    repairRibbon();
    runPageReveal();
    ensureLayeringScenes();
    if(!reduced){
      measureShop();
      requestRender();
      window.addEventListener('scroll', requestRender, {passive:true});
      window.addEventListener('resize', refreshSoon, {passive:true});
      window.addEventListener('orientationchange', refreshSoon, {passive:true});
      window.addEventListener('hashchange', function(){ var name=currentPageName(); onRouteChange(name); onLayeringRoute(name); });
      window.addEventListener('popstate', function(){ var name=currentPageName(); onRouteChange(name); onLayeringRoute(name); });
      window.addEventListener('tabaq:page-change', function(event){ var name = event && event.detail && event.detail.page ? event.detail.page : currentPageName(); onRouteChange(name); onLayeringRoute(name); });
      qsa('.shop-motion-bottle img,.rev52-role-product img').forEach(function(img){ if(!img.complete) img.addEventListener('load', refreshSoon, {once:true}); });
      if(document.fonts && document.fonts.ready){ document.fonts.ready.then(refreshSoon).catch(function(){}); }
    } else {
      var page = shopPage();
      if(page) setFallback(page);
    }
  }
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot, {once:true});
  else boot();
})();
/* REV40 — AWWWARDS DISCIPLINE + SHOP EDITORIAL MOTION POLISH END */
/* REV78 — INLINE SCRIPT BLOCK 10 END */


/* REV78 — INLINE SCRIPT BLOCK 11 START */
/* REV63 — HERO DECODER MOTION START
   Purpose: a restrained first-3-second explanatory text cycle. It uses the existing shell and does not create a second renderer. */
(function(){
  function ready(fn){ if(document.readyState === 'loading'){ document.addEventListener('DOMContentLoaded', fn, {once:true}); } else { fn(); } }
  ready(function(){
    var words = ['Choose one fragrance kit.', 'Body Mist lifts the scent.', 'Eau de Parfum defines it.', 'Two oils soften and switch.'];
    var word = document.querySelector('[data-rev63-hero-word]');
    var lines = Array.prototype.slice.call(document.querySelectorAll('.rev63-hero-line'));
    if(!word || !lines.length) return;
    var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var i = 0;
    function show(index){
      i = index % words.length;
      lines.forEach(function(line, n){ line.classList.toggle('is-lit', n === i); });
      if(reduced || !window.gsap){ word.textContent = words[i]; return; }
      window.gsap.to(word, {y:-10, opacity:0, duration:.18, ease:'power2.out', onComplete:function(){
        word.textContent = words[i];
        window.gsap.fromTo(word, {y:12, opacity:0}, {y:0, opacity:1, duration:.42, ease:'power3.out'});
      }});
      window.gsap.fromTo(lines[i], {y:2}, {y:-3, duration:.34, ease:'power3.out'});
    }
    show(0);
    window.setInterval(function(){ show(i+1); }, 2400);
  });
})();
/* REV63 — HERO DECODER MOTION END */
/* REV78 — INLINE SCRIPT BLOCK 11 END */


/* REV78 — INLINE SCRIPT BLOCK 12 START */
/* REV61 — FINAL HYBRID COMMERCE POLISH MOTION / INTERACTION START
   Purpose: one small finder interaction and subtle section reveal hooks. No new shell, renderer, page router or fallback nav. */
(function(){
  function ready(fn){ if(document.readyState === 'loading'){ document.addEventListener('DOMContentLoaded', fn, {once:true}); } else { fn(); } }
  ready(function(){
    document.documentElement.classList.add('rev61-quality-pass');
    var buttons = Array.prototype.slice.call(document.querySelectorAll('[data-rev61-kit]'));
    var result = document.querySelector('[data-rev61-finder-result]');
    if(buttons.length && result){
      var title = result.querySelector('strong');
      var copy = result.querySelector('p');
      var link = result.querySelector('[data-rev61-result-link]');
      buttons.forEach(function(btn){
        btn.addEventListener('click', function(){
          buttons.forEach(function(other){ other.classList.remove('is-active'); });
          btn.classList.add('is-active');
          var kitName = btn.getAttribute('data-rev61-kit') || 'Clean Skin';
          var text = btn.getAttribute('data-rev61-copy') || '';
          var page = btn.getAttribute('data-rev61-link') || 'product-clean-skin';
          if(title) title.textContent = kitName;
          if(copy) copy.textContent = text;
          if(link){
            link.setAttribute('data-page-link', page);
            link.setAttribute('href', '#' + page);
            link.textContent = 'View ' + kitName;
          }
          if(window.gsap && !(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches)){
            window.gsap.fromTo(result, {y:8, opacity:.76}, {y:0, opacity:1, duration:.34, ease:'power3.out'});
          }
        });
      });
    }
    if(window.gsap && window.ScrollTrigger){
      var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if(!reduced){
        window.gsap.utils.toArray('.rev61-layer-map span').forEach(function(el, index){
          window.gsap.to(el, {x:(index%2? -18:18), y:(index<2? 14:-14), rotation:index%2? -2:2, ease:'none', scrollTrigger:{trigger:'.rev61-clarity-band', start:'top bottom', end:'bottom top', scrub:true}});
        });
      }
    }
  });
})();
/* REV61 — FINAL HYBRID COMMERCE POLISH MOTION / INTERACTION END */
/* REV78 — INLINE SCRIPT BLOCK 12 END */


/* REV78 — INLINE SCRIPT BLOCK 13 START */
/* REV66 — GSAP SHOP MOTION SPECIALIST START
   Purpose: add disciplined product reveal motion and scroll depth without creating a second renderer. */
(function(){
  const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const ready = (fn) => document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', fn, { once:true }) : fn();
  ready(function(){
    const shop = document.querySelector('.tabaq-page[data-page="shop"]');
    if(!shop) return;
    const cards = Array.from(shop.querySelectorAll('.product-card.has-kit-motion'));
    const packs = cards.map(card => card.querySelector('.rev29-pack')).filter(Boolean);

    // Pointer depth: small, controlled 3D response only on the shop kit cards.
    cards.forEach((card) => {
      let raf = 0;
      const move = (event) => {
        if(reduce) return;
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          const box = card.getBoundingClientRect();
          const x = ((event.clientX - box.left) / Math.max(1, box.width)) - .5;
          const y = ((event.clientY - box.top) / Math.max(1, box.height)) - .5;
          card.style.setProperty('--rev66-tilt-x', (x * 3.2).toFixed(2) + 'deg');
          const pack = card.querySelector('.rev29-pack');
          if(pack && window.gsap){
            window.gsap.to(pack, { rotateY:x * 7, rotateX:4 - y * 5, duration:.55, ease:'power3.out', overwrite:'auto' });
          }
        });
      };
      const leave = () => {
        cancelAnimationFrame(raf);
        card.style.setProperty('--rev66-tilt-x','0deg');
        const pack = card.querySelector('.rev29-pack');
        if(pack && window.gsap && !pack.classList.contains('is-open')){
          window.gsap.to(pack, { rotateY:-3, rotateX:4, duration:.7, ease:'power3.out', overwrite:'auto' });
        }
      };
      card.addEventListener('pointermove', move, { passive:true });
      card.addEventListener('pointerleave', leave, { passive:true });
    });

    if(!window.gsap || reduce) return;
    const gsap = window.gsap;
    const ScrollTrigger = window.ScrollTrigger;
    if(ScrollTrigger){ gsap.registerPlugin(ScrollTrigger); }

    gsap.set(cards, { transformPerspective:1400, transformOrigin:'50% 62%' });
    cards.forEach((card, index) => {
      const preview = card.querySelector('.rev29-kit-preview');
      const copy = card.querySelector('.rev29-kit-copy');
      const meta = card.querySelector('.product-card__meta');
      if(ScrollTrigger){
        gsap.fromTo(card,
          { autoAlpha:0, y:70, rotateX:7, scale:.965 },
          { autoAlpha:1, y:0, rotateX:0, scale:1, duration:1.05, delay:index*.05, ease:'power4.out',
            scrollTrigger:{ trigger:card, start:'top 86%', once:true }
          }
        );
        if(preview){
          gsap.fromTo(preview,
            { y:34, scale:.94, rotateX:6 },
            { y:0, scale:1, rotateX:0, duration:1.15, ease:'expo.out',
              scrollTrigger:{ trigger:preview, start:'top 88%', once:true }
            }
          );
        }
        if(copy || meta){
          gsap.fromTo([copy, meta].filter(Boolean),
            { y:24, autoAlpha:0 },
            { y:0, autoAlpha:1, duration:.8, stagger:.08, ease:'power3.out',
              scrollTrigger:{ trigger:card, start:'top 78%', once:true }
            }
          );
        }
      }
    });

    // Sequential open-preview pass: each kit opens once when the shop grid enters view.
    const openPack = (pack, delay) => {
      window.setTimeout(() => {
        pack.classList.add('is-open');
        window.setTimeout(() => pack.classList.remove('is-open'), 1450);
      }, delay);
    };
    const runReveal = () => packs.forEach((pack, index) => openPack(pack, index * 260));
    if(ScrollTrigger){
      ScrollTrigger.create({
        trigger: shop.querySelector('.product-grid--animated-kits') || shop,
        start:'top 76%',
        once:true,
        onEnter:runReveal
      });
    }else if('IntersectionObserver' in window){
      const grid = shop.querySelector('.product-grid--animated-kits') || shop;
      const io = new IntersectionObserver((entries) => {
        entries.forEach(entry => { if(entry.isIntersecting){ runReveal(); io.disconnect(); } });
      }, { threshold:.22 });
      io.observe(grid);
    }
  });
})();
/* REV66 — GSAP SHOP MOTION SPECIALIST END */
/* REV78 — INLINE SCRIPT BLOCK 13 END */


/* REV78 — INLINE SCRIPT BLOCK 14 START */
/* REV68 — ANIMATION-SYNCED SHADOW RIG START
   Purpose: create real shadow layers per kit so shadows travel with the tray/cover motion. */
(function(){
  const ready = (fn) => document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', fn, { once:true }) : fn();
  ready(function(){
    const shop = document.querySelector('.tabaq-page[data-page="shop"]');
    if(!shop) return;
    shop.querySelectorAll('.rev29-pack').forEach((pack) => {
      if(pack.dataset.rev68ShadowRig === 'ready') return;
      pack.dataset.rev68ShadowRig = 'ready';
      const coverShadow = document.createElement('span');
      coverShadow.className = 'rev68-shadow rev68-shadow--cover';
      coverShadow.setAttribute('aria-hidden','true');
      const trayShadow = document.createElement('span');
      trayShadow.className = 'rev68-shadow rev68-shadow--tray';
      trayShadow.setAttribute('aria-hidden','true');
      pack.insertBefore(coverShadow, pack.firstChild);
      pack.insertBefore(trayShadow, coverShadow.nextSibling);
    });
  });
})();
/* REV68 — ANIMATION-SYNCED SHADOW RIG END */
/* REV78 — INLINE SCRIPT BLOCK 14 END */


/* REV78 — INLINE SCRIPT BLOCK 15 START */
/* REV70 — EARLY ACCESS ACTIVITY + PREMIUM DROP STRATEGY START
   Purpose: create a live-feeling activity feed without fake purchase claims. Purchase alerts must come from real checkout data later. */
(function(){
  const PRICE = {'clean-skin':'R890','soft-bloom':'R890','amber-haze':'R950','juice-drift':'R890'};
  const KIT_NAMES = {'clean-skin':'Clean Skin','soft-bloom':'Soft Bloom','amber-haze':'Amber Haze','juice-drift':'Juice Drift'};
  const sampleLineActivity = [
    ['Amina','Cape Town','clean-skin'],['Lina','Dubai','soft-bloom'],['Maya','London','amber-haze'],['Sofia','Madrid','juice-drift'],
    ['Zara','Johannesburg','clean-skin'],['Anika','Mumbai','soft-bloom'],['Nour','Doha','amber-haze'],['Ella','Amsterdam','juice-drift'],
    ['Thandi','Durban','clean-skin'],['Sara','Riyadh','soft-bloom'],['Leah','Toronto','amber-haze'],['Mei','Singapore','juice-drift']
  ];
  function normaliseFirstDropLabels(){
    document.querySelectorAll('[data-rev43-add]').forEach(function(btn){
      const id = btn.getAttribute('data-rev43-add') || 'clean-skin';
      const price = PRICE[id] || 'R890';
      const label = 'Join the early line — ' + price;
      btn.dataset.rev48Label = label;
      btn.dataset.rev51Label = label;
      if(!btn.classList.contains('is-added')) btn.textContent = label;
    });
  }
  function setHeroQuiet(){
    document.body.classList.toggle('is-hero-card-quiet', window.scrollY > 120);
  }
  const activity = document.getElementById('rev69DropActivity');
  const copy = activity ? activity.querySelector('[data-rev69-activity-copy]') : null;
  let messageIndex = 0;
  function messageFromSample(item){
    const name = item[0], city = item[1], kitId = item[2];
    return name + ' · ' + city + ' joined the early line for ' + (KIT_NAMES[kitId] || 'a TABAQ kit') + '.';
  }
  function showActivity(message){
    if(!activity || !copy) return;
    copy.textContent = message;
    activity.classList.remove('is-active');
    void activity.offsetWidth;
    activity.classList.add('is-active');
  }
  function rotateActivity(){
    const item = sampleLineActivity[messageIndex % sampleLineActivity.length];
    showActivity(messageFromSample(item));
    messageIndex += 1;
  }
  window.TABAQ_REAL_DROP_ACTIVITY = function(payload){
    if(!payload) return;
    const name = payload.name || 'Someone';
    const city = payload.city || 'the early line';
    const kit = payload.kit || 'a TABAQ kit';
    const action = payload.action === 'purchase' ? 'purchased' : 'joined the line for';
    showActivity(name + ' · ' + city + ' ' + action + ' ' + kit + '.');
  };
  window.addEventListener('scroll', setHeroQuiet, {passive:true});
  window.addEventListener('hashchange', normaliseFirstDropLabels);
  window.addEventListener('storage', normaliseFirstDropLabels);
  document.addEventListener('DOMContentLoaded', function(){
    normaliseFirstDropLabels();
    setHeroQuiet();
    window.setTimeout(rotateActivity, 800);
    window.setInterval(rotateActivity, 6200);
  });
  document.addEventListener('submit', function(event){
    if(event.target && event.target.id === 'rev49DropForm'){
      window.setTimeout(function(){
        const kit = (document.getElementById('rev49DropTitle') || {}).textContent || 'your kit';
        showActivity('You joined the early access line for ' + kit + '.');
        normaliseFirstDropLabels();
      }, 60);
    }
  }, true);
})();
/* REV70 — EARLY ACCESS ACTIVITY + PREMIUM DROP STRATEGY END */
/* REV78 — INLINE SCRIPT BLOCK 15 END */


/* REV78 — INLINE SCRIPT BLOCK 16 START */
/* REV72 — DESIGN CONSISTENCY + LAYERING MOTION START
   Purpose: simple GSAP-enhanced entrance polish for the new page briefs and Layering guide. No new router, no second renderer. */
(function(){
  function initRev72(){
    var prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var gsapReady = window.gsap && typeof window.gsap.fromTo === 'function';
    if(prefersReduced || !gsapReady) return;
    if(window.ScrollTrigger && gsap.registerPlugin){ try{ gsap.registerPlugin(ScrollTrigger); }catch(e){} }
    var ease = 'power3.out';
    document.querySelectorAll('.rev72-page-brief article').forEach(function(card, index){
      gsap.fromTo(card,{autoAlpha:0,y:18},{autoAlpha:1,y:0,duration:.65,ease:ease,delay:index*.045,scrollTrigger: window.ScrollTrigger ? {trigger:card,start:'top 88%',once:true} : null});
    });
    document.querySelectorAll('.rev72-layer-role').forEach(function(card, index){
      gsap.fromTo(card,{autoAlpha:0,y:34,rotate:index%2 ? 1.2 : -1.2},{autoAlpha:1,y:0,rotate:0,duration:.85,ease:ease,delay:index*.06,scrollTrigger: window.ScrollTrigger ? {trigger:card,start:'top 84%',once:true} : null});
      var img = card.querySelector('img');
      if(img){
        gsap.fromTo(img,{y:18,scale:.96},{y:0,scale:1,duration:.95,ease:'back.out(1.25)',delay:.1+index*.04,scrollTrigger: window.ScrollTrigger ? {trigger:card,start:'top 84%',once:true} : null});
      }
    });
    var bridge = document.querySelector('.rev72-layering-bridge');
    if(bridge){
      gsap.fromTo(bridge,{autoAlpha:0,y:30},{autoAlpha:1,y:0,duration:.75,ease:ease,scrollTrigger: window.ScrollTrigger ? {trigger:bridge,start:'top 86%',once:true} : null});
    }
  }
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initRev72, {once:true});
  else initRev72();
  window.addEventListener('tabaq:page-change', function(){ window.setTimeout(initRev72, 80); });
})();
/* REV72 — DESIGN CONSISTENCY + LAYERING MOTION END */
/* REV78 — INLINE SCRIPT BLOCK 16 END */


/* REV78 — INLINE SCRIPT BLOCK 17 START */
/* REV74 — REASONED 3D MOTION START
   Purpose: add spatial motion only to Rev74 identity and guide systems. Motion must explain lift, separation and settlement. */
(function(){
  function initRev74Motion(){
    var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if(reduced || !window.gsap) return;
    if(window.ScrollTrigger && gsap.registerPlugin){ try{ gsap.registerPlugin(ScrollTrigger); }catch(e){} }
    var cards = Array.prototype.slice.call(document.querySelectorAll('.rev74-step-card'));
    cards.forEach(function(card, index){
      var lift = index % 2 === 0 ? -18 : 18;
      var rot = [-7, 4, -3, 6][index] || 0;
      gsap.fromTo(card,
        {autoAlpha:0, y:46, z:-80, rotateX:7, rotateY:rot, transformPerspective:900, transformOrigin:'50% 80%'},
        {autoAlpha:1, y:0, z:0, rotateX:0, rotateY:0, duration:1.05, ease:'power3.out', delay:index*.07,
         scrollTrigger: window.ScrollTrigger ? {trigger:card, start:'top 86%', once:true} : null}
      );
      var object = card.querySelector('.rev74-step-object span');
      if(object){
        gsap.fromTo(object,
          {y:24 + Math.abs(lift), rotate:index%2 ? 4 : -4, scale:.94, transformOrigin:'50% 100%'},
          {y:0, rotate:0, scale:1, duration:1.15, ease:'elastic.out(1, .72)', delay:.08 + index*.08,
           scrollTrigger: window.ScrollTrigger ? {trigger:card, start:'top 86%', once:true} : null}
        );
      }
    });
    document.querySelectorAll('.rev74-identity-rules article, .rev74-layering-card').forEach(function(el, index){
      gsap.fromTo(el,
        {autoAlpha:0, y:22, rotate:index%2 ? .8 : -.8},
        {autoAlpha:1, y:0, rotate:0, duration:.72, ease:'power2.out', delay:(index%4)*.035,
         scrollTrigger: window.ScrollTrigger ? {trigger:el, start:'top 88%', once:true} : null}
      );
    });
    var map = document.querySelector('.rev74-identity-map');
    if(map && !map.dataset.rev74Pointer){
      map.dataset.rev74Pointer = 'true';
      map.addEventListener('pointermove', function(event){
        var r = map.getBoundingClientRect();
        var x = (event.clientX - r.left) / r.width - .5;
        var y = (event.clientY - r.top) / r.height - .5;
        cards.forEach(function(card, i){
          gsap.to(card,{rotateY:x*(i%2?5:8), rotateX:y*-5, x:x*(i+1)*3, y:y*(i+1)*-2, duration:.45, ease:'power2.out', overwrite:true});
        });
      }, {passive:true});
      map.addEventListener('pointerleave', function(){
        cards.forEach(function(card){ gsap.to(card,{rotateY:0, rotateX:0, x:0, y:0, duration:.65, ease:'power3.out', overwrite:true}); });
      }, {passive:true});
    }
  }
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initRev74Motion, {once:true});
  else initRev74Motion();
  window.addEventListener('tabaq:page-change', function(){ window.setTimeout(initRev74Motion, 90); });
})();
/* REV74 — REASONED 3D MOTION END */
/* REV78 — INLINE SCRIPT BLOCK 17 END */


/* REV78 — INLINE SCRIPT BLOCK 18 START */
/* REV75 — RUNTIME COPY GUARD START
   Purpose: protect customer-facing language generated by older revision scripts. */
(function(){
  function cleanText(value){
    if(!value) return value;
    return value
      .replace(/Join early line/g,'Join the early line')
      .replace(/Join Early Line/g,'Join the early line')
      .replace(/On Drop List/g,'On early line')
      .replace(/Drop List/g,'early line')
      .replace(/\bEDP\b/g,'Eau de Parfum')
      .replace(/price-cut noise/gi,'sale noise')
      .replace(/random pairing/gi,'bad pairing')
      .replace(/random bottle/gi,'loose bottle');
  }
  function run(){
    document.querySelectorAll('button,a,span,p,b,strong,small,h1,h2,h3,h4,li,em,label').forEach(function(el){
      if(el.children.length) return;
      var next = cleanText(el.textContent);
      if(next !== el.textContent) el.textContent = next;
    });
  }
  document.addEventListener('DOMContentLoaded', run);
  window.addEventListener('tabaq:page-change', function(){window.setTimeout(run,40);});
  window.setInterval(run,2500);
})();
/* REV75 — RUNTIME COPY GUARD END */
/* REV78 — INLINE SCRIPT BLOCK 18 END */


/* REV79 — GSAP COMMERCE MOTION PANEL START
   Purpose: add varied, product-led 3D motion to post-hero commerce sections only. Hero selectors are intentionally excluded. */
(function(){
  var REV79_SELECTOR = '.rev79-motion-card';
  var ZONE_SELECTOR = '.rev79-motion-zone';
  var REVEAL_PROFILES = [
    {x:-28,y:54,z:-80,rotateX:8,rotateY:-10,rotateZ:-1.6,duration:.78,ease:'power3.out'},
    {x:18,y:68,z:-120,rotateX:-6,rotateY:12,rotateZ:1.2,duration:.86,ease:'expo.out'},
    {x:-8,y:80,z:-150,rotateX:11,rotateY:6,rotateZ:-.7,duration:.92,ease:'power4.out'},
    {x:30,y:46,z:-60,rotateX:-9,rotateY:-7,rotateZ:1.6,duration:.74,ease:'back.out(1.35)'}
  ];
  function ready(fn){ if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', fn, {once:true}); else fn(); }
  function reduced(){ return window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches; }
  function init(){
    var cards = Array.prototype.slice.call(document.querySelectorAll(REV79_SELECTOR));
    if(!cards.length) return;
    if(!window.gsap || reduced()){
      cards.forEach(function(card){card.style.opacity='1';card.style.transform='none';});
      return;
    }
    if(window.ScrollTrigger && !gsap.core.globals().ScrollTrigger){ gsap.registerPlugin(window.ScrollTrigger); }
    cards.forEach(function(card, index){
      if(card.dataset.rev79MotionReady === 'true') return;
      card.dataset.rev79MotionReady = 'true';
      var p = REVEAL_PROFILES[index % REVEAL_PROFILES.length];
      gsap.fromTo(card,
        {autoAlpha:0,x:p.x,y:p.y,z:p.z,rotateX:p.rotateX,rotateY:p.rotateY,rotateZ:p.rotateZ,transformPerspective:1000,transformOrigin:'50% 70%',force3D:true},
        {autoAlpha:1,x:0,y:0,z:0,rotateX:0,rotateY:0,rotateZ:0,duration:p.duration,ease:p.ease,force3D:true,overwrite:true,
          scrollTrigger: window.ScrollTrigger ? {trigger:card,start:'top 88%',once:true} : null,
          delay:(index%4)*.035
        }
      );
    });
    Array.prototype.slice.call(document.querySelectorAll(ZONE_SELECTOR)).forEach(function(zone){
      if(zone.dataset.rev79PointerReady === 'true') return;
      zone.dataset.rev79PointerReady = 'true';
      var zoneCards = Array.prototype.slice.call(zone.querySelectorAll(REV79_SELECTOR));
      if(!zoneCards.length) return;
      zone.addEventListener('pointermove', function(event){
        var r = zone.getBoundingClientRect();
        var x = ((event.clientX - r.left) / Math.max(r.width,1)) - .5;
        var y = ((event.clientY - r.top) / Math.max(r.height,1)) - .5;
        zoneCards.forEach(function(card, i){
          var depth = Number(card.getAttribute('data-depth') || (i+1));
          gsap.to(card, {
            x:x * (6 + depth*2),
            y:y * (-5 - depth),
            rotateY:x * (5 + depth*1.5),
            rotateX:y * (-4 - depth),
            z:Math.abs(x+y) * (8 + depth*4),
            duration:.42 + (i%3)*.04,
            ease:'power3.out',
            overwrite:true,
            force3D:true
          });
        });
      }, {passive:true});
      zone.addEventListener('pointerleave', function(){
        zoneCards.forEach(function(card, i){
          gsap.to(card,{x:0,y:0,z:0,rotateX:0,rotateY:0,duration:.72 + (i%3)*.04,ease:'elastic.out(1,.72)',overwrite:true,force3D:true});
        });
      }, {passive:true});
    });
    if(window.ScrollTrigger) window.ScrollTrigger.refresh();
  }
  ready(init);
  window.addEventListener('tabaq:page-change', function(){ window.setTimeout(init, 80); });
})();
/* REV79 — GSAP COMMERCE MOTION PANEL END */





